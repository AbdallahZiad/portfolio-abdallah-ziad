---
export interface Props {
  title: string;
  description?: string;
}
const { title, description = "Stratum — Architecture & Interior Design Studio" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:        #161C14;
        --bg-2:      #1E2519;
        --ink:       #EAE8E0;
        --accent:    #C4953A;
        --accent-dk: #9A7228;
        --muted:     #8A9A7A;
        --dim:       #5A6A50;
        --surface:   #232E1D;
        --border:    rgba(234, 232, 224, 0.12);
        --line:      rgba(234, 232, 224, 0.07);

        --font-display: 'Cormorant Garamond', 'Times New Roman', Georgia, serif;
        --font-body:    'DM Sans', system-ui, sans-serif;

        --ease:      cubic-bezier(0.25, 0.46, 0.45, 0.94);
        --ease-out:  cubic-bezier(0.16, 1, 0.3, 1);

        --radius:      4px;
        --radius-pill: 100px;
        --shadow-sm:   0 2px 12px rgba(0, 0, 0, 0.30);
        --shadow:      0 8px 40px rgba(0, 0, 0, 0.40);
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: var(--font-body);
        background: var(--bg);
        color: var(--ink);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
      }

      a  { text-decoration: none; color: inherit; }
      button { border: none; background: none; cursor: pointer; font-family: inherit; }
      img, svg { max-width: 100%; display: block; }

      /* Scroll reveal */
      .reveal {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.75s var(--ease), transform 0.75s var(--ease);
      }
      .reveal.is-visible { opacity: 1; transform: none; }

      .d1 { transition-delay: 0.08s; }
      .d2 { transition-delay: 0.16s; }
      .d3 { transition-delay: 0.24s; }
      .d4 { transition-delay: 0.32s; }
      .d5 { transition-delay: 0.42s; }
      .d6 { transition-delay: 0.54s; }
    </style>
  </head>
  <body>
    <slot />
    <script is:inline>
      (function () {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.querySelectorAll('.reveal').forEach(function (el) {
            el.classList.add('is-visible');
          });
          return;
        }
        var obs = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              obs.unobserve(entry.target);
              entry.target.addEventListener('transitionend', function () {
                this.style.transitionDelay = '';
              }, { once: true });
            }
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -32px 0px' });
        document.querySelectorAll('.reveal').forEach(function (el) { obs.observe(el); });
      })();
    </script>
  </body>
</html>
