---
const demos = [
  {
    href: "/demo/1",
    name: "Nebula",
    tag: "AI SaaS Platform",
    variant: "saas",
    accent: "#a855f7",
    line: "rgba(168, 85, 247, 0.45)",
  },
  {
    href: "/demo/2",
    name: "Aurelia",
    tag: "Skincare · E-commerce",
    variant: "shop",
    accent: "#b0894a",
    line: "rgba(176, 137, 74, 0.5)",
  },
];
---

<section class="section" id="demos">
  <div class="container">
    <span class="eyebrow" data-reveal>Sample Landing Page Demos</span>
    <h2 class="section-title" data-reveal>Range across styles and industries.</h2>
    <p class="section-lead" data-reveal>
      Three landing page concepts, each with its own identity — designed and built
      to show range across styles, colors, and industries. Take a look inside.
    </p>

    <div class="demo-grid">
      {
        demos.map((d) => (
          <a
            class="demo-card glass"
            href={d.href}
            data-reveal
            style={`--accent:${d.accent};--line:${d.line}`}
            aria-label={`View the ${d.name} demo — ${d.tag}`}
          >
            <div class={`demo-preview demo-${d.variant}`}>
              {d.variant === "saas" && (
                <div class="pv-saas">
                  <div class="pv-bar">
                    <span class="pv-dot" /><span class="pv-dot" /><span class="pv-dot" />
                  </div>
                  <div class="pv-kpis">
                    <div class="pv-kpi"><b>48.2k</b><i>MAU</i></div>
                    <div class="pv-kpi"><b>63%</b><i>Retention</i></div>
                    <div class="pv-kpi"><b>$1.2M</b><i>Revenue</i></div>
                  </div>
                  <svg class="pv-chart" viewBox="0 0 200 60" preserveAspectRatio="none" aria-hidden="true">
                    <defs>
                      <linearGradient id="pvg" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0" stop-color="#a855f7" stop-opacity="0.35" />
                        <stop offset="1" stop-color="#a855f7" stop-opacity="0" />
                      </linearGradient>
                    </defs>
                    <path d="M0 46 C30 44 40 20 66 26 S110 40 132 22 168 6 200 12 L200 60 L0 60 Z" fill="url(#pvg)" />
                    <path d="M0 46 C30 44 40 20 66 26 S110 40 132 22 168 6 200 12" fill="none" stroke="#c084fc" stroke-width="2" />
                  </svg>
                </div>
              )}

              {d.variant === "shop" && (
                <div class="pv-shop">
                  <span class="pv-word">Aurelia</span>
                  <div class="pv-bottle">
                    <svg viewBox="0 0 40 72" aria-hidden="true">
                      <rect x="15" y="2" width="10" height="8" rx="2" fill="#8a6f45" />
                      <rect x="12" y="9" width="16" height="6" rx="2" fill="#a98a58" />
                      <rect x="8" y="15" width="24" height="52" rx="8" fill="#e9e0cd" stroke="#c9bfa4" />
                      <rect x="13" y="30" width="14" height="24" rx="3" fill="#fff" opacity="0.55" />
                    </svg>
                  </div>
                  <div class="pv-price">Midnight Serum · <b>$86</b></div>
                </div>
              )}
            </div>

            <div class="demo-meta">
              <span class="demo-name">{d.name}</span>
              <span class="demo-view">
                View demo
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </span>
            </div>
            <span class="demo-tag">{d.tag}</span>
          </a>
        ))
      }

      <!-- Coming Soon card -->
      <div class="demo-card demo-card--soon glass" data-reveal aria-label="Demo coming soon">
        <div class="demo-preview demo-soon">
          <div class="pv-soon">
            <svg class="pv-soon-ring" viewBox="0 0 80 80" aria-hidden="true">
              <circle cx="40" cy="40" r="30" fill="none" stroke="rgba(25,200,255,0.12)" stroke-width="1"/>
              <circle cx="40" cy="40" r="30" fill="none" stroke="rgba(25,200,255,0.5)" stroke-width="1.5"
                stroke-dasharray="18 8" stroke-linecap="round">
                <animateTransform attributeName="transform" type="rotate" from="0 40 40" to="360 40 40" dur="12s" repeatCount="indefinite"/>
              </circle>
              <circle cx="40" cy="40" r="18" fill="none" stroke="rgba(25,200,255,0.18)" stroke-width="1"
                stroke-dasharray="6 4">
                <animateTransform attributeName="transform" type="rotate" from="360 40 40" to="0 40 40" dur="8s" repeatCount="indefinite"/>
              </circle>
            </svg>
            <span class="pv-soon-label">Coming Soon</span>
          </div>
        </div>
        <div class="demo-meta">
          <span class="demo-name demo-name--soon">In Progress</span>
        </div>
        <span class="demo-tag">New concept · Stay tuned</span>
      </div>
    </div>
  </div>
</section>

<style>
  .demo-grid {
    margin-top: 54px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .demo-card {
    display: block;
    padding: 16px;
    transition: transform 0.4s var(--ease), border-color 0.4s var(--ease),
      box-shadow 0.4s var(--ease);
  }
  @media (hover: hover) {
    .demo-card:not(.demo-card--soon):hover {
      transform: translateY(-6px);
      border-color: var(--line);
      box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
    }
    .demo-card:not(.demo-card--soon):hover .demo-view {
      color: var(--accent);
    }
    .demo-card:not(.demo-card--soon):hover .demo-view svg {
      transform: translateX(4px);
    }
  }
  .demo-preview {
    position: relative;
    aspect-ratio: 16 / 11;
    border-radius: 12px;
    border: 1px solid var(--border);
    overflow: hidden;
  }

  /* ---- SaaS (Nebula) preview ---- */
  .demo-saas {
    background: radial-gradient(120% 100% at 100% 0%, rgba(168, 85, 247, 0.18), transparent 60%),
      #0b0a18;
    padding: 14px;
  }
  .pv-bar {
    display: flex;
    gap: 5px;
    margin-bottom: 12px;
  }
  .pv-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.18);
  }
  .pv-kpis {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 7px;
    margin-bottom: 12px;
  }
  .pv-kpi {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 8px 6px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .pv-kpi b {
    font-size: 0.82rem;
    color: #f0e9ff;
  }
  .pv-kpi i {
    font-style: normal;
    font-size: 0.56rem;
    letter-spacing: 0.04em;
    color: #a48fce;
    text-transform: uppercase;
  }
  .pv-chart {
    width: 100%;
    height: 42px;
    display: block;
  }

  /* ---- Shop (Aurelia) preview ---- */
  .demo-shop {
    background: radial-gradient(120% 120% at 50% 120%, #efe7d9, #f7f3ec);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px;
  }
  .pv-word {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.15rem;
    letter-spacing: 0.02em;
    color: #38452f;
  }
  .pv-bottle svg {
    width: 34px;
    height: auto;
    filter: drop-shadow(0 8px 10px rgba(56, 69, 47, 0.18));
  }
  .pv-price {
    font-size: 0.66rem;
    color: #6b6459;
    letter-spacing: 0.02em;
  }
  .pv-price b {
    color: #221f1a;
  }

  /* ---- Coming Soon card ---- */
  .demo-card--soon { cursor: default; }
  .demo-soon {
    background: radial-gradient(110% 110% at 50% 50%, rgba(25, 200, 255, 0.06), transparent 70%),
      var(--bg-2);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pv-soon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .pv-soon-ring { width: 72px; height: 72px; }
  .pv-soon-label {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--neon);
    opacity: 0.65;
  }
  .demo-name--soon { color: var(--text-muted); }

  /* ---- Meta row ---- */
  .demo-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 8px 2px;
  }
  .demo-name {
    font-weight: 650;
    font-size: 1rem;
    letter-spacing: -0.01em;
  }
  .demo-view {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--text-muted);
    transition: color 0.3s var(--ease);
  }
  .demo-view svg {
    width: 14px;
    height: 14px;
    transition: transform 0.3s var(--ease);
  }
  .demo-tag {
    display: block;
    padding: 0 8px;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--text-dim);
  }

  /* Tablet: 2-up hybrid. Third card spans the full row so nothing is orphaned. */
  @media (min-width: 641px) and (max-width: 980px) {
    .demo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .demo-card:nth-child(3) {
      grid-column: 1 / -1;
      max-width: 520px;
      margin-inline: auto;
      width: 100%;
    }
  }

  /* Phone: single column, centered. */
  @media (max-width: 640px) {
    .demo-grid {
      grid-template-columns: 1fr;
      max-width: 460px;
      margin-inline: auto;
    }
  }
</style>
