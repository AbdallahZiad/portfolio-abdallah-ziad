---
const demos = [
  {
    href: "/demo/1",
    name: "Nebula",
    tag: "AI SaaS Platform",
    preview: "/previews/demo1.jpg",
    accent: "#a855f7",
    line: "rgba(168, 85, 247, 0.45)",
  },
  {
    href: "/demo/2",
    name: "Aurelia",
    tag: "Skincare · E-commerce",
    preview: "/previews/demo2.jpg",
    accent: "#b0894a",
    line: "rgba(176, 137, 74, 0.5)",
  },
  {
    href: "/demo/3",
    name: "Stratum",
    tag: "Architecture Studio",
    preview: "/previews/demo3.jpg",
    accent: "#C4953A",
    line: "rgba(196, 149, 58, 0.45)",
  },
];
---

<section class="section" id="demos">
  <div class="container">
    <span class="eyebrow" data-reveal>Sample Landing Page Demos</span>
    <h2 class="section-title" data-reveal>Range across styles and industries.</h2>
    <p class="section-lead" data-reveal>
      Three landing page concepts, each with its own identity — designed and built
      to show range across styles, colors, and industries. Take a look inside.
    </p>

    <div class="demo-grid">
      {
        demos.map((d) => (
          <a
            class="demo-card glass"
            href={d.href}
            data-reveal
            style={`--accent:${d.accent};--line:${d.line}`}
            aria-label={`View the ${d.name} demo — ${d.tag}`}
          >
            <div class="demo-preview">
              <img
                src={d.preview}
                alt={`${d.name} demo preview`}
                class="demo-preview-img"
                loading="lazy"
                decoding="async"
              />
            </div>

            <div class="demo-meta">
              <span class="demo-name">{d.name}</span>
              <span class="demo-view">
                View demo
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </span>
            </div>
            <span class="demo-tag">{d.tag}</span>
          </a>
        ))
      }

    </div>
  </div>
</section>

<style>
  .demo-grid {
    margin-top: 54px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .demo-card {
    display: block;
    padding: 16px;
    transition: transform 0.4s var(--ease), border-color 0.4s var(--ease),
      box-shadow 0.4s var(--ease);
  }
  @media (hover: hover) {
    .demo-card:not(.demo-card--soon):hover {
      transform: translateY(-6px);
      border-color: var(--line);
      box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
    }
    .demo-card:not(.demo-card--soon):hover .demo-view {
      color: var(--accent);
    }
    .demo-card:not(.demo-card--soon):hover .demo-view svg {
      transform: translateX(4px);
    }
  }
  .demo-preview {
    position: relative;
    aspect-ratio: 16 / 11;
    border-radius: 12px;
    border: 1px solid var(--border);
    overflow: hidden;
  }

  /* ---- Screenshot previews ---- */
  .demo-preview-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  /* ---- Meta row ---- */
  .demo-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 8px 2px;
  }
  .demo-name {
    font-weight: 650;
    font-size: 1rem;
    letter-spacing: -0.01em;
  }
  .demo-view {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--text-muted);
    transition: color 0.3s var(--ease);
  }
  .demo-view svg {
    width: 14px;
    height: 14px;
    transition: transform 0.3s var(--ease);
  }
  .demo-tag {
    display: block;
    padding: 0 8px;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--text-dim);
  }

  /* Tablet: 2-up, third card alone on second row centered at half width */
  @media (min-width: 641px) and (max-width: 980px) {
    .demo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .demo-card:nth-child(3) {
      grid-column: 1 / -1;
      max-width: calc(50% - 12px);
      margin-inline: auto;
      width: 100%;
    }
  }

  /* Phone: single column, centered. */
  @media (max-width: 640px) {
    .demo-grid {
      grid-template-columns: 1fr;
      max-width: 460px;
      margin-inline: auto;
    }
  }
</style>
