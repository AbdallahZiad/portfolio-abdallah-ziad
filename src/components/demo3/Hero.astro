---
---
<section class="sh" id="top" aria-labelledby="sh-heading">
  <div class="sh-inner">

    <!-- ── Left: editorial copy ── -->
    <div class="sh-copy">

      <div class="sh-eyebrow reveal">
        <span class="sh-eyebrow-bar" aria-hidden="true"></span>
        Architecture · Interiors · Identity
      </div>

      <h1 class="sh-heading reveal d1" id="sh-heading">
        <em class="sh-word-light">Space,</em>
        <span class="sh-word-bold">crafted<br/>for<br/>living.</span>
      </h1>

      <p class="sh-desc reveal d2">
        We design spaces that endure. Stratum partners with
        forward-thinking clients to create architecture and interiors
        that are timeless, purposeful, and deeply personal.
      </p>

      <div class="sh-actions reveal d3">
        <a href="#work" class="sh-btn-primary">
          View our work
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
            <path d="M2.5 7.5h10M8.5 3.5l4 4-4 4" stroke="currentColor" stroke-width="1.4"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#studio" class="sh-btn-ghost">Our studio</a>
      </div>

      <div class="sh-stats reveal d4">
        <div class="sh-stat">
          <span class="sh-stat-n">24+</span>
          <span class="sh-stat-l">Years of practice</span>
        </div>
        <div class="sh-divider" aria-hidden="true"></div>
        <div class="sh-stat">
          <span class="sh-stat-n">180</span>
          <span class="sh-stat-l">Projects completed</span>
        </div>
        <div class="sh-divider" aria-hidden="true"></div>
        <div class="sh-stat">
          <span class="sh-stat-n">12</span>
          <span class="sh-stat-l">Countries</span>
        </div>
      </div>
    </div>

    <!-- ── Right: architectural elevation drawing ── -->
    <div class="sh-visual reveal d2" aria-hidden="true">
      <div class="sh-frame">
        <!-- Subtle grid overlay -->
        <div class="sh-grid"></div>

        <svg class="sh-svg" viewBox="0 0 500 580" fill="none"
          xmlns="http://www.w3.org/2000/svg" role="img"
          aria-label="Architectural elevation drawing of Stratum Residence No. 14">

          <!-- ── Ambient ground shadow ── -->
          <ellipse cx="248" cy="548" rx="192" ry="13"
            fill="rgba(13,12,10,0.06)"/>

          <!-- ── Main tower ── -->
          <!-- Outer wall -->
          <rect class="sd-wall" x="68" y="108" width="220" height="416"
            fill="#EDE8DE" stroke="#0D0C0A" stroke-width="1.3" pathLength="1"/>
          <!-- Roof accent band -->
          <rect class="sd-fill" x="68" y="98" width="220" height="12"
            fill="#C4953A"/>

          <!-- Floor division lines - main tower -->
          <line class="sd-line" x1="68"  y1="178" x2="288" y2="178" stroke="#0D0C0A" stroke-width="0.55" opacity="0.28" pathLength="1"/>
          <line class="sd-line" x1="68"  y1="248" x2="288" y2="248" stroke="#0D0C0A" stroke-width="0.55" opacity="0.28" pathLength="1"/>
          <line class="sd-line" x1="68"  y1="318" x2="288" y2="318" stroke="#0D0C0A" stroke-width="0.55" opacity="0.28" pathLength="1"/>
          <line class="sd-line" x1="68"  y1="388" x2="288" y2="388" stroke="#0D0C0A" stroke-width="0.55" opacity="0.28" pathLength="1"/>
          <line class="sd-line" x1="68"  y1="458" x2="288" y2="458" stroke="#0D0C0A" stroke-width="0.55" opacity="0.28" pathLength="1"/>

          <!-- Floor 1 windows -->
          <rect class="sd-win" x="90"  y="124" width="40" height="32" fill="rgba(195,180,158,0.38)" stroke="#0D0C0A" stroke-width="0.75" pathLength="1"/>
          <rect class="sd-win" x="148" y="124" width="40" height="32" fill="rgba(195,180,158,0.38)" stroke="#0D0C0A" stroke-width="0.75" pathLength="1"/>
          <rect class="sd-win" x="206" y="124" width="40" height="32" fill="rgba(195,180,158,0.38)" stroke="#0D0C0A" stroke-width="0.75" pathLength="1"/>

          <!-- Floor 2: curtain wall glazing -->
          <rect class="sd-win" x="90" y="190" width="178" height="32"
            fill="rgba(195,180,158,0.22)" stroke="#0D0C0A" stroke-width="0.75" pathLength="1"/>
          <line class="sd-line" x1="178" y1="190" x2="178" y2="222" stroke="#0D0C0A" stroke-width="0.5" opacity="0.35" pathLength="1"/>

          <!-- Floor 3 windows – accent-tinted -->
          <rect class="sd-win" x="90"  y="260" width="40" height="32"
            fill="rgba(196,149,58,0.20)" stroke="#0D0C0A" stroke-width="0.75" pathLength="1"/>
          <rect class="sd-win" x="148" y="260" width="40" height="32"
            fill="rgba(195,180,158,0.38)" stroke="#0D0C0A" stroke-width="0.75" pathLength="1"/>
          <rect class="sd-win" x="206" y="260" width="40" height="32"
            fill="rgba(196,149,58,0.20)" stroke="#0D0C0A" stroke-width="0.75" pathLength="1"/>

          <!-- Floor 4: curtain wall glazing -->
          <rect class="sd-win" x="90" y="330" width="178" height="32"
            fill="rgba(195,180,158,0.22)" stroke="#0D0C0A" stroke-width="0.75" pathLength="1"/>
          <line class="sd-line" x1="178" y1="330" x2="178" y2="362" stroke="#0D0C0A" stroke-width="0.5" opacity="0.35" pathLength="1"/>

          <!-- Floor 5 windows -->
          <rect class="sd-win" x="90"  y="400" width="40" height="32"
            fill="rgba(195,180,158,0.38)" stroke="#0D0C0A" stroke-width="0.75" pathLength="1"/>
          <rect class="sd-win" x="148" y="400" width="40" height="32"
            fill="rgba(196,149,58,0.20)" stroke="#0D0C0A" stroke-width="0.75" pathLength="1"/>
          <rect class="sd-win" x="206" y="400" width="40" height="32"
            fill="rgba(195,180,158,0.38)" stroke="#0D0C0A" stroke-width="0.75" pathLength="1"/>

          <!-- Floor 6 windows -->
          <rect class="sd-win" x="90"  y="468" width="40" height="28"
            fill="rgba(195,180,158,0.38)" stroke="#0D0C0A" stroke-width="0.75" pathLength="1"/>
          <rect class="sd-win" x="148" y="468" width="40" height="28"
            fill="rgba(195,180,158,0.38)" stroke="#0D0C0A" stroke-width="0.75" pathLength="1"/>
          <rect class="sd-win" x="206" y="468" width="40" height="28"
            fill="rgba(195,180,158,0.38)" stroke="#0D0C0A" stroke-width="0.75" pathLength="1"/>

          <!-- ── Side wing ── -->
          <rect class="sd-wall" x="288" y="198" width="132" height="326"
            fill="#E8E2D6" stroke="#0D0C0A" stroke-width="1.1" pathLength="1"/>
          <rect class="sd-fill" x="288" y="190" width="132" height="10"
            fill="#C4953A" opacity="0.82"/>

          <!-- Wing floor lines -->
          <line class="sd-line" x1="288" y1="268" x2="420" y2="268" stroke="#0D0C0A" stroke-width="0.5" opacity="0.25" pathLength="1"/>
          <line class="sd-line" x1="288" y1="338" x2="420" y2="338" stroke="#0D0C0A" stroke-width="0.5" opacity="0.25" pathLength="1"/>
          <line class="sd-line" x1="288" y1="408" x2="420" y2="408" stroke="#0D0C0A" stroke-width="0.5" opacity="0.25" pathLength="1"/>
          <line class="sd-line" x1="288" y1="458" x2="420" y2="458" stroke="#0D0C0A" stroke-width="0.5" opacity="0.25" pathLength="1"/>

          <!-- Wing windows row 1 -->
          <rect class="sd-win" x="306" y="214" width="36" height="28"
            fill="rgba(195,180,158,0.38)" stroke="#0D0C0A" stroke-width="0.7" pathLength="1"/>
          <rect class="sd-win" x="358" y="214" width="36" height="28"
            fill="rgba(196,149,58,0.20)" stroke="#0D0C0A" stroke-width="0.7" pathLength="1"/>

          <!-- Wing curtain wall -->
          <rect class="sd-win" x="306" y="280" width="88" height="28"
            fill="rgba(195,180,158,0.22)" stroke="#0D0C0A" stroke-width="0.7" pathLength="1"/>
          <line class="sd-line" x1="349" y1="280" x2="349" y2="308" stroke="#0D0C0A" stroke-width="0.45" opacity="0.32" pathLength="1"/>

          <!-- Wing windows row 3 -->
          <rect class="sd-win" x="306" y="350" width="36" height="28"
            fill="rgba(195,180,158,0.38)" stroke="#0D0C0A" stroke-width="0.7" pathLength="1"/>
          <rect class="sd-win" x="358" y="350" width="36" height="28"
            fill="rgba(195,180,158,0.38)" stroke="#0D0C0A" stroke-width="0.7" pathLength="1"/>

          <!-- Wing curtain wall -->
          <rect class="sd-win" x="306" y="420" width="88" height="28"
            fill="rgba(195,180,158,0.22)" stroke="#0D0C0A" stroke-width="0.7" pathLength="1"/>
          <line class="sd-line" x1="349" y1="420" x2="349" y2="448" stroke="#0D0C0A" stroke-width="0.45" opacity="0.32" pathLength="1"/>

          <!-- Wing windows row 5 -->
          <rect class="sd-win" x="306" y="466" width="36" height="26"
            fill="rgba(196,149,58,0.20)" stroke="#0D0C0A" stroke-width="0.7" pathLength="1"/>
          <rect class="sd-win" x="358" y="466" width="36" height="26"
            fill="rgba(195,180,158,0.38)" stroke="#0D0C0A" stroke-width="0.7" pathLength="1"/>

          <!-- ── Entry / ground floor ── -->
          <rect class="sd-wall" x="148" y="462" width="88" height="62"
            fill="rgba(195,180,158,0.28)" stroke="#0D0C0A" stroke-width="0.9" pathLength="1"/>
          <line class="sd-line" x1="192" y1="462" x2="192" y2="524" stroke="#0D0C0A" stroke-width="0.6" opacity="0.4" pathLength="1"/>
          <!-- Door handles -->
          <circle cx="183" cy="496" r="3" fill="#C4953A"/>
          <circle cx="201" cy="496" r="3" fill="#C4953A"/>

          <!-- ── Ground line ── -->
          <line class="sd-wall" x1="22" y1="524" x2="460" y2="524"
            stroke="#0D0C0A" stroke-width="1.1" opacity="0.45" pathLength="1"/>

          <!-- ── Architectural annotation lines ── -->
          <!-- Height dimension on left -->
          <line class="sd-anno" x1="40" y1="98"  x2="60" y2="98"  stroke="#0D0C0A" stroke-width="0.5" opacity="0.3" pathLength="1"/>
          <line class="sd-anno" x1="40" y1="524" x2="60" y2="524" stroke="#0D0C0A" stroke-width="0.5" opacity="0.3" pathLength="1"/>
          <line class="sd-anno" x1="46" y1="98"  x2="46" y2="524" stroke="#0D0C0A" stroke-width="0.5" opacity="0.3" pathLength="1"/>
          <!-- Dimension ticks -->
          <line class="sd-anno" x1="42" y1="98"  x2="50" y2="98"  stroke="#0D0C0A" stroke-width="0.6" opacity="0.32" pathLength="1"/>
          <line class="sd-anno" x1="42" y1="524" x2="50" y2="524" stroke="#0D0C0A" stroke-width="0.6" opacity="0.32" pathLength="1"/>

          <!-- Elevation label (rotated) -->
          <text x="28" y="310" font-family="'DM Sans', sans-serif" font-size="7.5"
            fill="#0D0C0A" opacity="0.32" letter-spacing="1.5"
            transform="rotate(-90 28 310)">ELEVATION · NORTH</text>

          <!-- Scale bar -->
          <g transform="translate(290, 542)">
            <line x1="0" y1="0"  x2="90" y2="0"  stroke="#0D0C0A" stroke-width="0.7" opacity="0.32"/>
            <line x1="0" y1="-4" x2="0"  y2="4"  stroke="#0D0C0A" stroke-width="0.7" opacity="0.32"/>
            <line x1="90" y1="-4" x2="90" y2="4" stroke="#0D0C0A" stroke-width="0.7" opacity="0.32"/>
            <line x1="45" y1="-3" x2="45" y2="3" stroke="#0D0C0A" stroke-width="0.5" opacity="0.22"/>
            <text x="45" y="15" text-anchor="middle" font-family="'DM Sans', sans-serif"
              font-size="7.5" fill="#0D0C0A" opacity="0.34" letter-spacing="0.5">10 m</text>
          </g>

          <!-- Compass rose -->
          <g transform="translate(454, 148)">
            <circle cx="0" cy="0" r="14" fill="none" stroke="#0D0C0A" stroke-width="0.6" opacity="0.26"/>
            <line x1="0" y1="-14" x2="0" y2="14" stroke="#0D0C0A" stroke-width="0.55" opacity="0.3"/>
            <line x1="-14" y1="0" x2="14" y2="0" stroke="#0D0C0A" stroke-width="0.55" opacity="0.3"/>
            <!-- North pointer -->
            <polygon points="0,-14 4,-4 0,-8 -4,-4" fill="#C4953A" opacity="0.7"/>
            <text x="0" y="-18" text-anchor="middle" font-family="'DM Sans', sans-serif"
              font-size="8" fill="#0D0C0A" opacity="0.36" font-weight="500">N</text>
          </g>

          <!-- Project ref tag (top right) -->
          <text x="418" y="102" text-anchor="end" font-family="'DM Sans', sans-serif"
            font-size="7" fill="#0D0C0A" opacity="0.28" letter-spacing="0.8">STR-014 / 1:100</text>
        </svg>
      </div>

      <!-- Caption below the frame -->
      <div class="sh-caption">
        <span class="sh-cap-name">Residence No. 14</span>
        <span class="sh-cap-loc">Porto, Portugal — 2024</span>
      </div>
    </div>

  </div><!-- /sh-inner -->

  <!-- ── Scrolling ticker ── -->
  <div class="sh-ticker" aria-hidden="true">
    <div class="sh-ticker-track">
      <span>Residential</span><span class="sh-dot">·</span>
      <span>Commercial</span><span class="sh-dot">·</span>
      <span>Hospitality</span><span class="sh-dot">·</span>
      <span>Cultural</span><span class="sh-dot">·</span>
      <span>Urban Planning</span><span class="sh-dot">·</span>
      <span>Interior Design</span><span class="sh-dot">·</span>
      <span>Landscape</span><span class="sh-dot">·</span>
      <span>Residential</span><span class="sh-dot">·</span>
      <span>Commercial</span><span class="sh-dot">·</span>
      <span>Hospitality</span><span class="sh-dot">·</span>
      <span>Cultural</span><span class="sh-dot">·</span>
      <span>Urban Planning</span><span class="sh-dot">·</span>
      <span>Interior Design</span><span class="sh-dot">·</span>
      <span>Landscape</span><span class="sh-dot">·</span>
    </div>
  </div>
</section>

<style>
  /* ── Layout ── */
  .sh {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    padding-top: 72px;
    overflow: hidden;
  }

  .sh-inner {
    flex: 1;
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    padding: 64px 48px 48px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }

  /* ── Copy ── */
  .sh-eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 30px;
  }
  .sh-eyebrow-bar {
    display: block;
    width: 28px;
    height: 1.5px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .sh-heading {
    font-family: var(--font-display);
    font-size: clamp(3.6rem, 5.5vw, 5.6rem);
    line-height: 1.04;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 28px;
  }
  .sh-word-light {
    display: block;
    font-weight: 300;
    font-style: italic;
    color: var(--muted);
  }
  .sh-word-bold {
    display: block;
    font-weight: 600;
    font-style: normal;
  }

  .sh-desc {
    font-size: 1rem;
    line-height: 1.78;
    font-weight: 300;
    color: var(--muted);
    max-width: 440px;
    margin-bottom: 40px;
  }

  .sh-actions {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 60px;
    flex-wrap: wrap;
  }

  .sh-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--ink);
    color: var(--bg);
    padding: 14px 28px;
    border-radius: var(--radius-pill);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    transition: background 0.25s var(--ease), transform 0.25s var(--ease-out),
      box-shadow 0.25s var(--ease);
    box-shadow: 0 2px 16px rgba(13,12,10,0.18);
  }
  @media (hover: hover) {
    .sh-btn-primary:hover {
      background: var(--accent);
      transform: translateY(-2px);
      box-shadow: 0 6px 28px rgba(196,149,58,0.35);
    }
  }

  .sh-btn-ghost {
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: var(--muted);
    padding-bottom: 3px;
    border-bottom: 1px solid var(--border);
    transition: color 0.22s, border-color 0.22s;
  }
  @media (hover: hover) {
    .sh-btn-ghost:hover { color: var(--ink); border-color: var(--ink); }
  }

  .sh-stats {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .sh-stat {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .sh-stat-n {
    font-family: var(--font-display);
    font-size: 2.1rem;
    font-weight: 300;
    line-height: 1;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .sh-stat-l {
    font-size: 0.66rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .sh-divider {
    width: 1px;
    height: 44px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* ── Visual / drawing ── */
  .sh-visual {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 14px;
  }

  .sh-frame {
    position: relative;
    border: 1px solid var(--border);
    border-radius: 3px;
    overflow: hidden;
    background: #F0EBE0;
    box-shadow: var(--shadow);
  }

  .sh-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(13,12,10,0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(13,12,10,0.045) 1px, transparent 1px);
    background-size: 36px 36px;
    pointer-events: none;
    z-index: 1;
  }

  .sh-svg {
    width: 100%;
    height: auto;
    display: block;
    position: relative;
    z-index: 2;
  }

  /* Drawing-in animations */
  @media (prefers-reduced-motion: no-preference) {
    .sd-wall {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
      animation: sh-draw 1.4s var(--ease-out) 0.3s forwards;
    }
    .sd-fill {
      opacity: 0;
      animation: sh-fadein 0.5s ease 1.4s forwards;
    }
    .sd-line {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
      animation: sh-draw 0.8s var(--ease-out) 1.2s forwards;
    }
    .sd-win {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
      opacity: 0;
      animation: sh-win 0.5s ease forwards;
    }
    .sd-anno {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
      animation: sh-draw 0.6s ease 2.0s forwards;
    }

    /* Stagger windows */
    .sh-svg rect.sd-win:nth-of-type(3)  { animation-delay: 1.40s; }
    .sh-svg rect.sd-win:nth-of-type(4)  { animation-delay: 1.46s; }
    .sh-svg rect.sd-win:nth-of-type(5)  { animation-delay: 1.52s; }
    .sh-svg rect.sd-win:nth-of-type(6)  { animation-delay: 1.55s; }
    .sh-svg rect.sd-win:nth-of-type(7)  { animation-delay: 1.58s; }
    .sh-svg rect.sd-win:nth-of-type(8)  { animation-delay: 1.61s; }
    .sh-svg rect.sd-win:nth-of-type(9)  { animation-delay: 1.64s; }
    .sh-svg rect.sd-win:nth-of-type(10) { animation-delay: 1.68s; }
    .sh-svg rect.sd-win:nth-of-type(11) { animation-delay: 1.72s; }
    .sh-svg rect.sd-win:nth-of-type(12) { animation-delay: 1.76s; }
    .sh-svg rect.sd-win:nth-of-type(13) { animation-delay: 1.80s; }
    .sh-svg rect.sd-win:nth-of-type(14) { animation-delay: 1.84s; }
    .sh-svg rect.sd-win:nth-of-type(15) { animation-delay: 1.88s; }
    .sh-svg rect.sd-win:nth-of-type(16) { animation-delay: 1.92s; }
    .sh-svg rect.sd-win:nth-of-type(17) { animation-delay: 1.96s; }
    .sh-svg rect.sd-win:nth-of-type(18) { animation-delay: 2.00s; }
    .sh-svg rect.sd-win:nth-of-type(19) { animation-delay: 2.04s; }
    .sh-svg rect.sd-win:nth-of-type(20) { animation-delay: 2.08s; }
    .sh-svg rect.sd-win:nth-of-type(21) { animation-delay: 2.12s; }
    .sh-svg rect.sd-win:nth-of-type(22) { animation-delay: 2.16s; }
  }

  @keyframes sh-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes sh-fadein {
    to { opacity: 1; }
  }
  @keyframes sh-win {
    to { stroke-dashoffset: 0; opacity: 1; }
  }

  .sh-caption {
    display: flex;
    align-items: baseline;
    justify-content: flex-end;
    gap: 14px;
  }
  .sh-cap-name {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
  }
  .sh-cap-loc {
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dim);
  }

  /* ── Ticker ── */
  .sh-ticker {
    border-top: 1px solid var(--border);
