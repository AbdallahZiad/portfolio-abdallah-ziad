---
---
<section class="st" id="studio" aria-labelledby="st-heading">
  <div class="st-inner">

    <!-- Left: text -->
    <div class="st-copy">
      <span class="st-eyebrow reveal">
        <span class="st-bar" aria-hidden="true"></span>
        The Studio
      </span>

      <h2 class="st-heading reveal d1" id="st-heading">
        Built on the<br/>belief that<br/><em>place matters.</em>
      </h2>

      <blockquote class="st-quote reveal d2">
        "Good architecture doesn't announce itself. It simply makes
        you feel, without knowing why, that you are exactly where
        you should be."
        <cite>— Clara Voss, Founding Partner</cite>
      </blockquote>

      <p class="st-body reveal d3">
        Founded in 2000 and headquartered in Porto, Stratum has grown
        from a two-person practice into an internationally recognised
        studio with offices in Lisbon and London. We believe that the
        built environment shapes how people think, feel, and relate
        to one another — and we take that responsibility seriously.
      </p>

      <div class="st-figures reveal d4">
        <div class="st-fig">
          <span class="st-fig-n">3</span>
          <span class="st-fig-l">Offices</span>
        </div>
        <div class="st-fig-sep" aria-hidden="true"></div>
        <div class="st-fig">
          <span class="st-fig-n">48</span>
          <span class="st-fig-l">People</span>
        </div>
        <div class="st-fig-sep" aria-hidden="true"></div>
        <div class="st-fig">
          <span class="st-fig-n">7</span>
          <span class="st-fig-l">Awards in 2023</span>
        </div>
      </div>
    </div>

    <!-- Right: abstract architectural composition -->
    <div class="st-visual reveal d2" aria-hidden="true">
      <div class="st-plan-frame">
        <!-- Floor plan overhead view -->
        <svg class="st-plan-svg" viewBox="0 0 460 520" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Background -->
          <rect width="460" height="520" fill="#E8E2D4"/>

          <!-- Grid -->
          <defs>
            <pattern id="st-grid" width="30" height="30" patternUnits="userSpaceOnUse">
              <path d="M 30 0 L 0 0 0 30" fill="none" stroke="rgba(13,12,10,0.06)" stroke-width="0.6"/>
            </pattern>
          </defs>
          <rect width="460" height="520" fill="url(#st-grid)"/>

          <!-- ── Floor plan: Plan view of a villa ── -->
          <!-- Outer wall -->
          <rect x="48" y="60" width="364" height="390" fill="#DDD8CC" stroke="#0D0C0A" stroke-width="3"/>
          <!-- Inner wall cutout (open plan) -->
          <rect x="56" y="68" width="348" height="374" fill="#F0EBE0"/>

          <!-- Interior walls -->
          <!-- Vertical divider (left third / right two-thirds) -->
          <line x1="178" y1="68" x2="178" y2="290" stroke="#0D0C0A" stroke-width="3"/>
          <!-- Horizontal divider in right section -->
          <line x1="178" y1="200" x2="404" y2="200" stroke="#0D0C0A" stroke-width="3"/>
          <!-- Second horizontal -->
          <line x1="178" y1="290" x2="404" y2="290" stroke="#0D0C0A" stroke-width="3"/>
          <!-- Right side vertical divider (bathroom) -->
          <line x1="304" y1="200" x2="304" y2="290" stroke="#0D0C0A" stroke-width="2"/>
          <!-- Lower section horizontal -->
          <line x1="56" y1="370" x2="404" y2="370" stroke="#0D0C0A" stroke-width="3"/>
          <!-- Lower vertical -->
          <line x1="240" y1="370" x2="240" y2="442" stroke="#0D0C0A" stroke-width="2"/>

          <!-- Room fills -->
          <!-- Living area (big, left bottom) -->
          <rect x="57" y="291" width="120" height="78" fill="#EAE4D8" opacity="0.6"/>
          <!-- Kitchen (top left section) -->
          <rect x="57" y="69" width="120" height="130" fill="#E6E0D4" opacity="0.6"/>
          <!-- Master bedroom top right -->
          <rect x="179" y="69" width="224" height="130" fill="#EAE4D8" opacity="0.55"/>
          <!-- Bathroom -->
          <rect x="179" y="201" width="124" height="88" fill="#E2DCCE" opacity="0.7"/>
          <!-- Study/dressing -->
          <rect x="305" y="201" width="98" height="88" fill="#E6E0D4" opacity="0.55"/>
          <!-- Bedroom 2 -->
          <rect x="179" y="291" width="224" height="78" fill="#EAE4D8" opacity="0.55"/>

          <!-- Terrace (bottom) -->
          <rect x="57" y="371" width="346" height="70" fill="#E0D8C8" opacity="0.5"/>
          <!-- Terrace pattern (tiles) -->
          <line x1="57"  y1="395" x2="403" y2="395" stroke="#0D0C0A" stroke-width="0.4" opacity="0.18"/>
          <line x1="57"  y1="419" x2="403" y2="419" stroke="#0D0C0A" stroke-width="0.4" opacity="0.18"/>
          <line x1="117" y1="371" x2="117" y2="441" stroke="#0D0C0A" stroke-width="0.4" opacity="0.18"/>
          <line x1="177" y1="371" x2="177" y2="441" stroke="#0D0C0A" stroke-width="0.4" opacity="0.18"/>
          <line x1="237" y1="371" x2="237" y2="441" stroke="#0D0C0A" stroke-width="0.4" opacity="0.18"/>
          <line x1="297" y1="371" x2="297" y2="441" stroke="#0D0C0A" stroke-width="0.4" opacity="0.18"/>
          <line x1="357" y1="371" x2="357" y2="441" stroke="#0D0C0A" stroke-width="0.4" opacity="0.18"/>

          <!-- Windows (shown as gaps with tick marks) -->
          <!-- Top wall windows -->
          <line x1="80"  y1="58" x2="80"  y2="68" stroke="#0D0C0A" stroke-width="1.5"/>
          <line x1="80"  y1="60" x2="140" y2="60" stroke="white" stroke-width="4"/>
          <line x1="140" y1="58" x2="140" y2="68" stroke="#0D0C0A" stroke-width="1.5"/>

          <line x1="200" y1="58" x2="200" y2="68" stroke="#0D0C0A" stroke-width="1.5"/>
          <line x1="200" y1="60" x2="360" y2="60" stroke="white" stroke-width="4"/>
          <line x1="360" y1="58" x2="360" y2="68" stroke="#0D0C0A" stroke-width="1.5"/>

          <!-- Right wall windows -->
          <line x1="410" y1="90"  x2="412" y2="90"  stroke="#0D0C0A" stroke-width="1.5"/>
          <line x1="412" y1="90"  x2="412" y2="160" stroke="white" stroke-width="5"/>
          <line x1="410" y1="160" x2="412" y2="160" stroke="#0D0C0A" stroke-width="1.5"/>

          <line x1="410" y1="220" x2="412" y2="220" stroke="#0D0C0A" stroke-width="1.5"/>
          <line x1="412" y1="220" x2="412" y2="280" stroke="white" stroke-width="5"/>
          <line x1="410" y1="280" x2="412" y2="280" stroke="#0D0C0A" stroke-width="1.5"/>

          <!-- Doors (shown as arcs) -->
          <!-- Living room door -->
          <line x1="178" y1="305" x2="178" y2="291" stroke="white" stroke-width="3"/>
          <path d="M178 305 A24 24 0 0 0 154 305" stroke="#0D0C0A" stroke-width="0.9" fill="none"/>
          <line x1="178" y1="305" x2="154" y2="305" stroke="#0D0C0A" stroke-width="0.7" opacity="0.4"/>

          <!-- Entry door from terrace -->
          <line x1="200" y1="370" x2="240" y2="370" stroke="white" stroke-width="3"/>
          <path d="M200 370 A40 40 0 0 1 200 410" stroke="#0D0C0A" stroke-width="0.9" fill="none"/>
          <line x1="200" y1="370" x2="200" y2="410" stroke="#0D0C0A" stroke-width="0.7" opacity="0.4"/>

          <!-- Bathroom door -->
          <line x1="220" y1="200" x2="244" y2="200" stroke="white" stroke-width="3"/>
          <path d="M220 200 A24 24 0 0 0 220 224" stroke="#0D0C0A" stroke-width="0.9" fill="none"/>
          <line x1="220" y1="200" x2="220" y2="224" stroke="#0D0C0A" stroke-width="0.7" opacity="0.4"/>

          <!-- Bathroom fixtures (toilet, sink) -->
          <ellipse cx="230" cy="254" rx="10" ry="14" fill="none" stroke="#0D0C0A" stroke-width="0.8" opacity="0.35"/>
          <rect x="264" y="207" width="22" height="16" rx="4" fill="none" stroke="#0D0C0A" stroke-width="0.7" opacity="0.35"/>

          <!-- Kitchen counter -->
          <rect x="63" y="74" width="108" height="18" fill="#C8C0B0" stroke="#0D0C0A" stroke-width="0.6" opacity="0.7"/>
          <rect x="63" y="74" width="30" height="18" fill="#D0C8B8"/>

          <!-- Furniture suggestions -->
          <!-- Sofa -->
          <rect x="66" y="308" width="80" height="36" rx="4" fill="none" stroke="#0D0C0A" stroke-width="0.8" opacity="0.3"/>
          <rect x="66" y="308" width="80" height="12" rx="2" fill="rgba(13,12,10,0.07)"/>

          <!-- Bed master -->
          <rect x="220" y="84" width="60" height="80" rx="3" fill="none" stroke="#0D0C0A" stroke-width="0.8" opacity="0.3"/>
          <rect x="220" y="84" width="60" height="20" rx="2" fill="rgba(13,12,10,0.07)"/>

          <!-- Bed 2 -->
          <rect x="220" y="302" width="56" height="52" rx="3" fill="none" stroke="#0D0C0A" stroke-width="0.8" opacity="0.3"/>
          <rect x="220" y="302" width="56" height="16" rx="2" fill="rgba(13,12,10,0.07)"/>

          <!-- Dining table -->
          <ellipse cx="120" cy="330" rx="40" ry="26" fill="none" stroke="#0D0C0A" stroke-width="0.7" opacity="0.28"/>

          <!-- Pool (outside terrace) -->
          <rect x="80" y="450" width="200" height="48" rx="8" fill="rgba(130,170,190,0.4)" stroke="#0D0C0A" stroke-width="1" opacity="0.6"/>
          <rect x="80" y="450" width="200" height="6" rx="2" fill="#C4953A" opacity="0.5"/>

          <!-- Dimension lines (right side) -->
          <line x1="422" y1="60"  x2="442" y2="60"  stroke="#0D0C0A" stroke-width="0.5" opacity="0.28"/>
          <line x1="422" y1="450" x2="442" y2="450" stroke="#0D0C0A" stroke-width="0.5" opacity="0.28"/>
          <line x1="432" y1="60"  x2="432" y2="450" stroke="#0D0C0A" stroke-width="0.5" opacity="0.28"/>
          <text x="436" y="260" font-family="'DM Sans', sans-serif" font-size="7" fill="#0D0C0A" opacity="0.3" letter-spacing="1" transform="rotate(90 436 260)">PLAN · 1:50</text>

          <!-- North indicator -->
          <g transform="translate(36, 484)">
            <circle cx="0" cy="0" r="10" fill="none" stroke="#0D0C0A" stroke-width="0.6" opacity="0.3"/>
            <line x1="0" y1="-10" x2="0" y2="10" stroke="#0D0C0A" stroke-width="0.5" opacity="0.3"/>
            <line x1="-10" y1="0" x2="10" y2="0" stroke="#0D0C0A" stroke-width="0.5" opacity="0.3"/>
            <polygon points="0,-10 3,-4 0,-7 -3,-4" fill="#C4953A" opacity="0.65"/>
            <text x="0" y="-13" text-anchor="middle" font-family="'DM Sans', sans-serif" font-size="6" fill="#0D0C0A" opacity="0.32" font-weight="500">N</text>
          </g>
        </svg>
      </div>

      <div class="st-plan-caption">
        <span class="st-plan-label">Floor plan</span>
        <span class="st-plan-loc">Residence No. 14 · Ground level</span>
      </div>
    </div>

  </div>
</section>

<style>
  .st {
    padding: 120px 0;
    background: var(--bg-2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .st-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 48px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  /* Copy */
  .st-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 22px;
  }
  .st-bar {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .st-heading {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 3.2vw, 3.2rem);
    font-weight: 300;
    line-height: 1.12;
    color: var(--ink);
    margin-bottom: 32px;
  }
  .st-heading em {
    font-style: italic;
    color: var(--accent);
  }

  .st-quote {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 300;
    font-style: italic;
    line-height: 1.65;
    color: var(--muted);
    border-left: 2px solid var(--accent);
    padding-left: 20px;
    margin-bottom: 28px;
  }
  .st-quote cite {
    display: block;
    font-family: var(--font-body);
    font-style: normal;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dim);
    margin-top: 10px;
  }

  .st-body {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--muted);
    font-weight: 300;
    margin-bottom: 40px;
  }

  .st-figures {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .st-fig { display: flex; flex-direction: column; gap: 4px; }
  .st-fig-n {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 300;
    color: var(--ink);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .st-fig-l {
    font-size: 0.66rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .st-fig-sep {
    width: 1px;
    height: 40px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* Visual */
  .st-visual {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .st-plan-frame {
    border: 1px solid var(--border);
    border-radius: 3px;
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .st-plan-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .st-plan-caption {
    display: flex;
    align-items: baseline;
    justify-content: flex-end;
    gap: 14px;
  }
  .st-plan-label {
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
  }
  .st-plan-loc {
    font-size: 0.66rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dim);
  }

  /* Responsive */
  @media (max-width: 1100px) {
    .st-inner { padding: 0 36px; gap: 56px; }
  }

  @media (max-width: 860px) {
    .st { padding: 80px 0; }
    .st-inner {
      grid-template-columns: 1fr;
      gap: 52px;
      padding: 0 32px;
    }
  }

  @media (max-width: 560px) {
    .st { padding: 64px 0; }
    .st-inner { padding: 0 20px; }
    .st-figures { gap: 16px; }
    .st-fig-n { font-size: 1.7rem; }
    .st-heading { font-size: clamp(2.2rem, 7vw, 2.8rem); }
  }
</style>
