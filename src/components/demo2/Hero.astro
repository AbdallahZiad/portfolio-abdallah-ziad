---
---
<section class="hero" aria-label="Hero">
  <div class="hero-inner">
    <!-- Text side -->
    <div class="hero-content">
      <span class="hero-eyebrow reveal">Botanical Skincare</span>
      <h1 class="hero-headline reveal delay-1">
        The quiet luxury<br />
        <em>of a daily ritual.</em>
      </h1>
      <p class="hero-sub reveal delay-2">
        Clean, clinically-considered formulas made with cold-pressed botanicals —
        for skin that looks like skin, only better.
      </p>
      <div class="hero-ctas reveal delay-3">
        <a href="#shop" class="btn-primary">Shop the collection</a>
        <a href="#ritual" class="btn-text">
          Discover the ritual
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Visual side -->
    <div class="hero-visual reveal delay-2" aria-hidden="true">
      <div class="hero-glow"></div>
      <div class="hero-pedestal">
        <!-- Botanical leaf accents -->
        <svg class="leaf leaf-left" viewBox="0 0 80 120" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M40 110 C20 80, 5 60, 10 30 C15 10, 35 5, 40 5 C40 5, 40 5, 40 5" stroke="#6f7d5f" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M40 110 C40 85, 15 70, 8 45" stroke="#6f7d5f" stroke-width="1" fill="none" stroke-linecap="round" opacity="0.6"/>
          <!-- Small leaves -->
          <path d="M25 75 C15 65, 12 50, 20 48 C28 46, 30 58, 25 75Z" fill="#6f7d5f" fill-opacity="0.18"/>
          <path d="M20 55 C10 45, 8 30, 16 28 C24 26, 26 38, 20 55Z" fill="#6f7d5f" fill-opacity="0.22"/>
          <path d="M32 35 C22 25, 20 10, 28 8 C36 6, 38 18, 32 35Z" fill="#6f7d5f" fill-opacity="0.20"/>
        </svg>

        <svg class="leaf leaf-right" viewBox="0 0 80 120" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M40 110 C60 80, 75 60, 70 30 C65 10, 45 5, 40 5" stroke="#6f7d5f" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M40 110 C40 85, 65 70, 72 45" stroke="#6f7d5f" stroke-width="1" fill="none" stroke-linecap="round" opacity="0.6"/>
          <path d="M55 75 C65 65, 68 50, 60 48 C52 46, 50 58, 55 75Z" fill="#6f7d5f" fill-opacity="0.18"/>
          <path d="M60 55 C70 45, 72 30, 64 28 C56 26, 54 38, 60 55Z" fill="#6f7d5f" fill-opacity="0.22"/>
          <path d="M48 35 C58 25, 60 10, 52 8 C44 6, 42 18, 48 35Z" fill="#6f7d5f" fill-opacity="0.20"/>
        </svg>

        <!-- Hero serum bottle SVG -->
        <svg class="hero-bottle" viewBox="0 0 140 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Aurelia Midnight Renewal Serum bottle">
          <!-- Glass body with warm tint -->
          <defs>
            <linearGradient id="bottle-grad" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#c8a97a" stop-opacity="0.35"/>
              <stop offset="35%" stop-color="#e8d8b8" stop-opacity="0.55"/>
              <stop offset="65%" stop-color="#d4b87e" stop-opacity="0.40"/>
              <stop offset="100%" stop-color="#9e7c4a" stop-opacity="0.30"/>
            </linearGradient>
            <linearGradient id="cap-grad" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#8a6535"/>
              <stop offset="50%" stop-color="#c9963e"/>
              <stop offset="100%" stop-color="#7a5828"/>
            </linearGradient>
            <linearGradient id="liquid-grad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#c4a46a" stop-opacity="0.70"/>
              <stop offset="100%" stop-color="#8c6635" stop-opacity="0.85"/>
            </linearGradient>
            <linearGradient id="highlight-grad" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="white" stop-opacity="0"/>
              <stop offset="30%" stop-color="white" stop-opacity="0.55"/>
              <stop offset="55%" stop-color="white" stop-opacity="0.20"/>
              <stop offset="100%" stop-color="white" stop-opacity="0"/>
            </linearGradient>
            <filter id="bottle-shadow" x="-30%" y="-5%" width="160%" height="115%">
              <feDropShadow dx="0" dy="8" stdDeviation="10" flood-color="#b08050" flood-opacity="0.25"/>
            </filter>
            <clipPath id="bottle-clip">
              <path d="M42 90 C36 92, 28 100, 28 110 L28 260 C28 272, 34 278, 70 278 C106 278, 112 272, 112 260 L112 110 C112 100, 104 92, 98 90 Z"/>
            </clipPath>
            <clipPath id="hero-label-clip">
              <rect x="35" y="120" width="70" height="95" rx="3"/>
            </clipPath>
          </defs>

          <!-- Bottle shadow on pedestal -->
          <ellipse cx="70" cy="282" rx="32" ry="7" fill="rgba(176,137,74,0.18)"/>

          <!-- Main bottle body -->
          <path d="M42 90 C36 92, 28 100, 28 110 L28 260 C28 272, 34 278, 70 278 C106 278, 112 272, 112 260 L112 110 C112 100, 104 92, 98 90 Z"
            fill="url(#bottle-grad)" stroke="#c9a86c" stroke-width="1.2" filter="url(#bottle-shadow)"/>

          <!-- Liquid fill inside -->
          <rect x="29" y="145" width="82" height="132" fill="url(#liquid-grad)" clip-path="url(#bottle-clip)" opacity="0.6"/>

          <!-- Glass highlight stripe -->
          <path d="M44 95 C41 100, 37 112, 37 140 L37 262" stroke="url(#highlight-grad)" stroke-width="5" stroke-linecap="round" opacity="0.9"/>

          <!-- Label area -->
          <rect x="35" y="120" width="70" height="95" rx="3" fill="rgba(247,243,236,0.78)" stroke="rgba(176,137,74,0.30)" stroke-width="0.8"/>

          <!-- Label text clipped to label rect -->
          <g clip-path="url(#hero-label-clip)">
            <text x="70" y="145" text-anchor="middle" font-family="Georgia, serif" font-size="10" font-style="italic" font-weight="400" fill="#38452f" letter-spacing="0.5">Aurelia</text>
            <line x1="45" y1="150" x2="95" y2="150" stroke="#b0894a" stroke-width="0.6" opacity="0.6"/>
            <text x="70" y="163" text-anchor="middle" font-family="Georgia, serif" font-size="6.5" font-weight="400" fill="#221f1a" letter-spacing="1.5">MIDNIGHT</text>
            <text x="70" y="172" text-anchor="middle" font-family="Georgia, serif" font-size="6.5" font-weight="400" fill="#221f1a" letter-spacing="1.5">RENEWAL</text>
            <line x1="55" y1="177" x2="85" y2="177" stroke="#b0894a" stroke-width="0.5" opacity="0.5"/>
            <text x="70" y="188" text-anchor="middle" font-family="Georgia, serif" font-size="5.5" fill="#6b6459" letter-spacing="0.8">Overnight Serum</text>
            <text x="70" y="203" text-anchor="middle" font-family="Georgia, serif" font-size="5" fill="#6b6459" letter-spacing="0.5">30 ml / 1 fl oz</text>
          </g>

          <!-- Bottle shoulder / neck -->
          <path d="M42 90 C38 78, 48 68, 56 56 L56 38 L84 38 L84 56 C92 68, 102 78, 98 90 Z"
            fill="url(#bottle-grad)" stroke="#c9a86c" stroke-width="1.2"/>
          <!-- Shoulder highlight -->
          <path d="M50 85 C48 76, 52 68, 58 58 L60 42" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.35"/>

          <!-- Dropper cap -->
          <rect x="54" y="14" width="32" height="28" rx="4" fill="url(#cap-grad)"/>
          <!-- Cap highlight -->
          <rect x="57" y="16" width="6" height="24" rx="3" fill="white" opacity="0.18"/>
          <!-- Dropper tip bulb -->
          <ellipse cx="70" cy="12" rx="9" ry="6" fill="#8a6535"/>
          <ellipse cx="67" cy="10" rx="3" ry="2" fill="white" opacity="0.25"/>
          <!-- Neck ring (gold collar) -->
          <rect x="53" y="36" width="34" height="5" rx="1.5" fill="#c9963e"/>
          <rect x="55" y="37" width="8" height="3" rx="1" fill="white" opacity="0.20"/>
        </svg>

        <!-- Small botanical sprig below -->
        <svg class="sprig" viewBox="0 0 120 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M10 20 Q60 5, 110 20" stroke="#6f7d5f" stroke-width="1.2" fill="none" stroke-linecap="round" opacity="0.55"/>
          <ellipse cx="30" cy="14" rx="8" ry="4" fill="#6f7d5f" fill-opacity="0.20" transform="rotate(-20, 30, 14)"/>
          <ellipse cx="50" cy="9" rx="8" ry="4" fill="#6f7d5f" fill-opacity="0.22" transform="rotate(-8, 50, 9)"/>
          <ellipse cx="70" cy="8" rx="9" ry="4" fill="#6f7d5f" fill-opacity="0.20" transform="rotate(5, 70, 8)"/>
          <ellipse cx="90" cy="12" rx="8" ry="4" fill="#6f7d5f" fill-opacity="0.18" transform="rotate(18, 90, 12)"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="scroll-hint" aria-hidden="true">
    <span class="scroll-line"></span>
    <span class="scroll-label">Scroll</span>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100svh - 64px - 38px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: linear-gradient(165deg, var(--bg) 0%, var(--bg-2) 55%, #e4dace 100%);
    padding: 80px 24px 100px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -100px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(176,137,74,0.07) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 64px;
    align-items: center;
  }

  @media (min-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr 1fr;
      gap: 80px;
    }
  }

  .hero-eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }

  .hero-headline {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 5.5vw, 4.2rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 24px;
  }

  .hero-headline em {
    font-style: italic;
    color: var(--green);
  }

  .hero-sub {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--muted);
    max-width: 460px;
    margin-bottom: 40px;
    font-weight: 300;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    align-items: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--green);
    color: #f7f3ec;
    padding: 14px 28px;
    border-radius: var(--radius-pill);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: background 0.25s ease, transform 0.25s var(--ease-out-expo), box-shadow 0.25s ease;
    box-shadow: 0 2px 12px rgba(56,69,47,0.18);
  }

  @media (hover: hover) {
    .btn-primary:hover {
      background: var(--ink);
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(34,31,26,0.22);
    }
  }

  .btn-text {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink);
    position: relative;
    padding-bottom: 2px;
    transition: gap 0.25s ease, color 0.2s ease;
  }

  .btn-text::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--gold);
  }

  @media (hover: hover) {
    .btn-text:hover {
      color: var(--gold);
      gap: 11px;
    }
  }

  /* Visual / Bottle */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    position: relative;
    min-height: 380px;
  }

  .hero-glow {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 260px;
    height: 260px;
    background: radial-gradient(circle, rgba(176,137,74,0.16) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .hero-pedestal {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .leaf {
    position: absolute;
    bottom: 60px;
    width: 80px;
    height: 120px;
  }

  .leaf-left {
    left: -60px;
    transform: rotate(-10deg);
    animation: leaf-sway-l 7s ease-in-out infinite;
  }

  .leaf-right {
    right: -60px;
    transform: rotate(10deg);
    animation: leaf-sway-r 8s ease-in-out infinite;
    animation-delay: 1s;
  }

  @keyframes leaf-sway-l {
    0%, 100% { transform: rotate(-10deg); }
    50% { transform: rotate(-5deg) translateX(-3px); }
  }

  @keyframes leaf-sway-r {
    0%, 100% { transform: rotate(10deg); }
    50% { transform: rotate(5deg) translateX(3px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .leaf-left, .leaf-right { animation: none; }
  }

  .hero-bottle {
    width: 160px;
    height: auto;
    position: relative;
    z-index: 2;
    filter: drop-shadow(0 24px 40px rgba(176,137,74,0.22));
    animation: bottle-float 6s ease-in-out infinite;
  }

  @keyframes bottle-float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bottle { animation: none; }
  }

  .sprig {
    width: 120px;
    opacity: 0.7;
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: var(--muted);
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, transparent, var(--gold));
    animation: scroll-line 2.5s ease-in-out infinite;
  }

  @keyframes scroll-line {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(0.7); }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-line { animation: none; }
  }

  .scroll-label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 500;
  }
</style>
