---
const points = [
  {
    label: "Refillable Glass",
    desc: "Every bottle is designed for a refill — the outer shell lives forever.",
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="24" cy="24" r="22" stroke="rgba(247,243,236,0.25)" stroke-width="1"/>
      <path d="M16 32 L16 20 C16 16, 19 14, 24 14 C29 14, 32 16, 32 20 L32 32 C32 36, 29 38, 24 38 C19 38, 16 36, 16 32Z" fill="none" stroke="rgba(247,243,236,0.80)" stroke-width="1.5" stroke-linejoin="round"/>
      <path d="M20 14 C20 11, 22 10, 24 10 C26 10, 28 11, 28 14" fill="none" stroke="rgba(247,243,236,0.80)" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M18 22 L30 22" stroke="rgba(247,243,236,0.50)" stroke-width="1" stroke-linecap="round"/>
      <path d="M19 26 Q24 28, 29 26" stroke="rgba(247,243,236,0.40)" stroke-width="1" stroke-linecap="round"/>
      <path d="M28 8 L30 10 L28 12" stroke="rgba(176,137,74,0.90)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M30 10 L20 10" stroke="rgba(176,137,74,0.90)" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    label: "Carbon-Neutral Shipping",
    desc: "Every shipment offset through verified reforestation and renewable energy projects.",
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="24" cy="24" r="22" stroke="rgba(247,243,236,0.25)" stroke-width="1"/>
      <path d="M10 30 L24 14 L38 30" fill="none" stroke="rgba(247,243,236,0.80)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M14 30 L24 18 L34 30" fill="none" stroke="rgba(247,243,236,0.50)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M18 30 L24 22 L30 30" fill="rgba(247,243,236,0.15)" stroke="rgba(247,243,236,0.40)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
      <line x1="24" y1="30" x2="24" y2="38" stroke="rgba(247,243,236,0.70)" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M18 38 L30 38" stroke="rgba(176,137,74,0.90)" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    label: "Cruelty-Free & Vegan",
    desc: "No animal testing, ever. No animal-derived ingredients. Certified by Leaping Bunny.",
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="24" cy="24" r="22" stroke="rgba(247,243,236,0.25)" stroke-width="1"/>
      <path d="M24 34 C18 30, 12 26, 12 20 C12 16, 14 13, 18 13 C20 13, 22 14, 24 17 C26 14, 28 13, 30 13 C34 13, 36 16, 36 20 C36 26, 30 30, 24 34Z" fill="none" stroke="rgba(247,243,236,0.80)" stroke-width="1.5" stroke-linejoin="round"/>
      <path d="M17 20 Q20 18, 24 20 Q28 18, 31 20" stroke="rgba(176,137,74,0.80)" stroke-width="1" stroke-linecap="round" fill="none"/>
      <!-- Bunny ears -->
      <path d="M18 13 Q14 6, 16 4" stroke="rgba(247,243,236,0.60)" stroke-width="1.2" stroke-linecap="round" fill="none"/>
      <path d="M30 13 Q34 6, 32 4" stroke="rgba(247,243,236,0.60)" stroke-width="1.2" stroke-linecap="round" fill="none"/>
    </svg>`,
  },
];
---

<section class="sustainability" aria-label="Sustainability commitments">
  <div class="sustainability-inner">
    <div class="sustain-header reveal">
      <h2 class="sustain-headline">
        Refillable.<br/>Recyclable.<br/><em>Responsible.</em>
      </h2>
    </div>

    <div class="sustain-points">
      {points.map((p, i) => (
        <div class={`sustain-point reveal delay-${i + 1}`}>
          <div class="sustain-icon" aria-hidden="true" set:html={p.icon}></div>
          <h3 class="sustain-label">{p.label}</h3>
          <p class="sustain-desc">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .sustainability {
    padding: 100px 24px;
    background: var(--green);
    position: relative;
    overflow: hidden;
  }

  .sustainability::before {
    content: '';
    position: absolute;
    top: -80px;
    right: -80px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(176,137,74,0.12) 0%, transparent 65%);
    pointer-events: none;
  }

  .sustainability::after {
    content: '';
    position: absolute;
    bottom: -60px;
    left: -60px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(247,243,236,0.06) 0%, transparent 65%);
    pointer-events: none;
  }

  .sustainability-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 64px;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 900px) {
    .sustainability-inner {
      grid-template-columns: 1fr 2fr;
      gap: 80px;
      align-items: center;
    }
  }

  .sustain-headline {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 400;
    color: rgba(247, 243, 236, 0.95);
    line-height: 1.08;
  }

  .sustain-headline em {
    font-style: italic;
    color: var(--gold);
  }

  .sustain-points {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 640px) {
    .sustain-points {
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }
  }

  .sustain-point {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .sustain-icon {
    width: 48px;
    height: 48px;
  }

  .sustain-icon svg {
    width: 48px;
    height: 48px;
  }

  .sustain-label {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 500;
    color: rgba(247, 243, 236, 0.95);
    letter-spacing: -0.01em;
  }

  .sustain-desc {
    font-size: 0.88rem;
    line-height: 1.7;
    color: rgba(247, 243, 236, 0.65);
    font-weight: 300;
  }
</style>
