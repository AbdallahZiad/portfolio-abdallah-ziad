                <path d="M35 72 C32 78, 29 88, 29 105 L29 195" stroke="white" stroke-width="4" stroke-linecap="round" opacity="0.32"/>
                <rect x="30" y="84" width="50" height="64" rx="2" fill="rgba(247,243,236,0.78)" stroke="rgba(176,137,74,0.20)" stroke-width="0.7"/>
                <g clip-path={`url(#lbl-s-${product.id})`}>
                  <text x="55" y="103" text-anchor="middle" font-family="Georgia,serif" font-size="7.5" font-style="italic" fill="#38452f">Aurelia</text>
                  <line x1="37" y1="107" x2="73" y2="107" stroke="#b0894a" stroke-width="0.5" opacity="0.5"/>
                  <text x="55" y="118" text-anchor="middle" font-family="Georgia,serif" font-size="5.5" fill="#221f1a" letter-spacing="1.5">MIDNIGHT</text>
                  <text x="55" y="127" text-anchor="middle" font-family="Georgia,serif" font-size="5.5" fill="#221f1a" letter-spacing="1.5">RENEWAL</text>
                  <text x="55" y="140" text-anchor="middle" font-family="Georgia,serif" font-size="4.5" fill="#6b6459">30 ml</text>
                </g>
