---
const products = [
  {
    id: "midnight-serum",
    name: "Midnight Renewal Serum",
    desc: "Overnight retinal serum",
    price: "$86",
    bottleType: "serum",
    tint: { body: "#c9a870", dark: "#8a6535", liquid: "#c4924a" },
  },
  {
    id: "dewpoint-essence",
    name: "Dewpoint Hydrating Essence",
    desc: "Hyaluronic + polyglutamic acid",
    price: "$52",
    bottleType: "essence",
    tint: { body: "#8fb5c0", dark: "#456470", liquid: "#9ecbda" },
  },
  {
    id: "sunlace-spf",
    name: "Sunlace Mineral SPF 45",
    desc: "Weightless zinc daily shield",
    price: "$44",
    bottleType: "tube",
    tint: { body: "#e0c890", dark: "#a08a40", liquid: "#e8d87e" },
  },
  {
    id: "rosewater-toner",
    name: "Rosewater Calm Toner",
    desc: "Alcohol-free pH mist",
    price: "$38",
    bottleType: "mist",
    tint: { body: "#d4a0a8", dark: "#8a5058", liquid: "#e8b4b8" },
  },
  {
    id: "golden-hour-oil",
    name: "Golden Hour Facial Oil",
    desc: "Rosehip + sea buckthorn",
    price: "$68",
    bottleType: "dropper",
    tint: { body: "#e0a040", dark: "#8a5a10", liquid: "#f0b848" },
  },
  {
    id: "silt-mask",
    name: "Silt Renewing Clay Mask",
    desc: "French clay + willow bark",
    price: "$46",
    bottleType: "jar",
    tint: { body: "#a89080", dark: "#5a4035", liquid: "#c4a88c" },
  },
];
---
<section class="shop-grid" id="shop" aria-labelledby="shop-heading">
  <div class="shop-inner">
    <div class="shop-header">
      <span class="section-eyebrow reveal">The Collection</span>
      <h2 class="section-title reveal delay-1" id="shop-heading">Formulas worth<br/><em>the ritual.</em></h2>
    </div>

    <div class="products-grid">
      {products.map((product, i) => (
        <article class={`product-card reveal delay-${Math.min(i + 1, 6)}`} data-product={product.id} aria-label={product.name}>
          <div class="card-visual" aria-hidden="true">
            {product.bottleType === "serum" && (
              <svg class="card-bottle" viewBox="0 0 110 220" fill="none" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <linearGradient id={`grad-s-${product.id}`} x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stop-color={product.tint.dark} stop-opacity="0.35"/>
                    <stop offset="40%" stop-color={product.tint.body} stop-opacity="0.60"/>
                    <stop offset="100%" stop-color={product.tint.dark} stop-opacity="0.30"/>
                  </linearGradient>
                  <linearGradient id={`liq-s-${product.id}`} x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color={product.tint.liquid} stop-opacity="0.60"/>
                    <stop offset="100%" stop-color={product.tint.dark} stop-opacity="0.75"/>
                  </linearGradient>
                  <clipPath id={`clip-s-${product.id}`}>
                    <path d="M32 68 C28 70, 22 76, 22 84 L22 192 C22 200, 26 204, 55 204 C84 204, 88 200, 88 192 L88 84 C88 76, 82 70, 78 68 Z"/>
                  </clipPath>
                  <clipPath id={`lbl-s-${product.id}`}>
                    <rect x="30" y="84" width="50" height="64" rx="2"/>
                  </clipPath>
                </defs>
                <ellipse cx="55" cy="208" rx="26" ry="5" fill={`${product.tint.dark}44`}/>
                <path d="M32 68 C28 70, 22 76, 22 84 L22 192 C22 200, 26 204, 55 204 C84 204, 88 200, 88 192 L88 84 C88 76, 82 70, 78 68 Z" fill={`url(#grad-s-${product.id})`} stroke={product.tint.body} stroke-width="1"/>
