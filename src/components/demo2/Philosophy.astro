      <path d="M20 8 L20 10 Q22 14, 24 16 Q28 20, 28 25 C28 31, 24 34, 20 34 C16 34, 12 31, 12 25 C12 20, 16 16, 18 14 Q20 12, 20 10 Z" fill="none" stroke="#8fb5c0" stroke-width="1.2"/>
      <path d="M20 13 Q22 16, 23 19 Q25 23, 25 26 C25 29, 23 31, 20 31" stroke="#8fb5c0" stroke-width="0.9" stroke-linecap="round" fill="none" opacity="0.60"/>
      <circle cx="20" cy="8" r="2" fill="#8fb5c0" fill-opacity="0.70"/>
      <ellipse cx="21" cy="26" rx="3" ry="4" fill="#8fb5c0" fill-opacity="0.14"/>
