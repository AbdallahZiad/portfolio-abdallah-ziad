---

<section class="philosophy" id="ingredients" aria-labelledby="philosophy-heading">
  <div class="philosophy-inner">
    <div class="philosophy-text">
      <span class="section-eyebrow reveal">Our Philosophy</span>
      <h2 class="philosophy-heading reveal delay-1" id="philosophy-heading">
        Formulated with<br/><em>restraint.</em>
      </h2>
      <p class="philosophy-body reveal delay-2">
        Every Aurelia formula begins with a question: does this ingredient earn its place?
        We use no fillers, no synthetic fragrance, and nothing you couldn't trace to a field or a forest.
        The result is a short, purposeful ingredient list — and skin that genuinely responds.
      </p>
      <p class="philosophy-body reveal delay-3">
        Cruelty-free. Vegan. Clinically tested. Made in small batches in certified facilities.
        The luxury is in the restraint.
      </p>
    </div>

    <div class="ingredients-grid">
      {ingredients.map((ing, i) => (
        <div class={`ingredient-card reveal delay-${i + 1}`}>
          <div class="ingredient-icon" aria-hidden="true" set:html={ing.icon}></div>
          <div class="ingredient-text">
            <h3 class="ingredient-name">{ing.name}</h3>
            <p class="ingredient-benefit">{ing.benefit}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .philosophy {
    padding: 100px 24px;
    background: var(--bg);
    border-top: 1px solid var(--line);
  }

  .philosophy-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 72px;
    align-items: start;
  }

  @media (min-width: 900px) {
    .philosophy-inner {
      grid-template-columns: 1fr 1fr;
      gap: 96px;
      align-items: center;
    }
  }

  .section-eyebrow {
    display: block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .philosophy-heading {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 28px;
  }

  .philosophy-heading em {
    font-style: italic;
    color: var(--green);
  }

  .philosophy-body {
    font-size: 0.98rem;
    line-height: 1.8;
    color: var(--muted);
    margin-bottom: 16px;
    font-weight: 300;
    max-width: 440px;
  }

  /* Ingredients grid */
  .ingredients-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .ingredient-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 28px 24px;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    transition: box-shadow 0.3s ease, transform 0.3s var(--ease-out-expo), border-color 0.3s ease;
  }

  @media (hover: hover) {
    .ingredient-card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-3px);
      border-color: rgba(176,137,74,0.22);
    }
  }

  .ingredient-icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }

  .ingredient-icon svg {
    width: 40px;
    height: 40px;
  }

  .ingredient-name {
    font-family: var(--font-serif);
    font-size: 0.98rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .ingredient-benefit {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.65;
    font-weight: 300;
  }
</style>
