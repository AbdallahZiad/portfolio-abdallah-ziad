---
const ingredients = [
  {
    name: "Cold-pressed Rosehip",
    benefit: "Brightens and visibly reduces post-blemish marks with natural vitamin A and C.",
    icon: `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="20" cy="20" r="10" fill="none" stroke="#b0894a" stroke-width="1.2"/>
      <ellipse cx="20" cy="20" rx="4" ry="4" fill="#b0894a" fill-opacity="0.20"/>
      <path d="M20 8 C16 11, 14 15, 14 20 C14 25, 16 29, 20 32" stroke="#6f7d5f" stroke-width="1.2" stroke-linecap="round" fill="none"/>
      <path d="M20 8 C24 11, 26 15, 26 20 C26 25, 24 29, 20 32" stroke="#6f7d5f" stroke-width="1.2" stroke-linecap="round" fill="none"/>
      <path d="M14 16 Q20 13, 26 16" stroke="#6f7d5f" stroke-width="0.9" stroke-linecap="round" fill="none" opacity="0.6"/>
      <path d="M14 24 Q20 27, 26 24" stroke="#6f7d5f" stroke-width="0.9" stroke-linecap="round" fill="none" opacity="0.6"/>
      <circle cx="20" cy="7" r="2.5" fill="#b56a4a" fill-opacity="0.70"/>
    </svg>`,
  },
  {
    name: "Encapsulated Retinal",
    benefit: "10× more potent than retinol, time-released for maximum efficacy with minimal irritation.",
    icon: `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="20" cy="20" r="10" fill="none" stroke="#b0894a" stroke-width="1.2"/>
      <circle cx="20" cy="20" r="6" fill="none" stroke="#b0894a" stroke-width="0.8" stroke-dasharray="2 2"/>
      <circle cx="20" cy="20" r="3" fill="#b0894a" fill-opacity="0.30"/>
      <circle cx="20" cy="20" r="1.5" fill="#b0894a" fill-opacity="0.60"/>
      <line x1="20" y1="8" x2="20" y2="11" stroke="#b0894a" stroke-width="1.2" stroke-linecap="round"/>
      <line x1="20" y1="29" x2="20" y2="32" stroke="#b0894a" stroke-width="1.2" stroke-linecap="round"/>
      <line x1="8" y1="20" x2="11" y2="20" stroke="#b0894a" stroke-width="1.2" stroke-linecap="round"/>
      <line x1="29" y1="20" x2="32" y2="20" stroke="#b0894a" stroke-width="1.2" stroke-linecap="round"/>
    </svg>`,
  },
  {
    name: "Bakuchiol",
    benefit: "Plant-derived retinol alternative. Reduces fine lines without sensitivity or sun avoidance.",
    icon: `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 32 C14 28, 10 22, 10 16 C10 10, 14 6, 20 6 C26 6, 30 10, 30 16 C30 22, 26 28, 20 32Z" fill="none" stroke="#6f7d5f" stroke-width="1.2"/>
      <path d="M20 32 C20 20, 13 12, 10 8" stroke="#6f7d5f" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.50"/>
      <path d="M20 32 C20 20, 27 12, 30 8" stroke="#6f7d5f" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.50"/>
      <path d="M14 20 Q20 17, 26 20" stroke="#6f7d5f" stroke-width="0.9" stroke-linecap="round" fill="none"/>
      <path d="M12 13 Q20 10, 28 13" stroke="#6f7d5f" stroke-width="0.9" stroke-linecap="round" fill="none" opacity="0.6"/>
      <circle cx="20" cy="33" r="2" fill="#6f7d5f" fill-opacity="0.50"/>
    </svg>`,
