---
const reviews = [
  {
    quote: "My skin has never looked calmer. Three weeks and I've retired half my shelf.",
    author: "Naomi R.",
    location: "New York",
    product: "Midnight Renewal Serum",
  },
  {
    quote: "The Dewpoint Essence layers beautifully under everything. My skin drinks it up every morning. I've repurchased three times.",
    author: "Céline M.",
    location: "London",
    product: "Dewpoint Hydrating Essence",
  },
  {
    quote: "Finally an SPF that doesn't leave a white cast or feel heavy. I've been looking for this for years. The texture is extraordinary.",
    author: "Priya T.",
    location: "Melbourne",
    product: "Sunlace Mineral SPF 45",
  },
];
---

<section class="reviews" aria-labelledby="reviews-heading">
  <div class="reviews-inner">
    <div class="reviews-header">
      <span class="section-eyebrow reveal">From the Community</span>
      <h2 class="reviews-heading reveal delay-1" id="reviews-heading">
        Skin that speaks<br/><em>for itself.</em>
      </h2>
    </div>

    <div class="reviews-grid">
      {reviews.map((r, i) => (
        <blockquote class={`review-card reveal delay-${i + 1}`}>
          <div class="review-stars" aria-label="5 out of 5 stars">
            <span aria-hidden="true">★★★★★</span>
          </div>
          <p class="review-quote">"{r.quote}"</p>
          <footer class="review-footer">
            <cite class="review-author">{r.author}</cite>
            <span class="review-meta">{r.location} · {r.product}</span>
          </footer>
        </blockquote>
      ))}
    </div>

    <!-- Trust metrics -->
    <div class="trust-row reveal">
      <div class="trust-stat">
        <span class="trust-num">4.9</span>
        <span class="trust-label">Average rating</span>
      </div>
      <div class="trust-divider" aria-hidden="true"></div>
      <div class="trust-stat">
        <span class="trust-num">2,400+</span>
        <span class="trust-label">Verified reviews</span>
      </div>
      <div class="trust-divider" aria-hidden="true"></div>
      <div class="trust-stat">
        <span class="trust-num">94%</span>
        <span class="trust-label">Would repurchase</span>
      </div>
    </div>
  </div>
</section>

<style>
  .reviews {
    padding: 100px 24px;
    background: var(--bg);
    border-top: 1px solid var(--line);
  }

  .reviews-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .reviews-header {
    margin-bottom: 56px;
  }

  .section-eyebrow {
    display: block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 14px;
  }

  .reviews-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 400;
    color: var(--ink);
    line-height: 1.12;
  }

  .reviews-heading em {
    font-style: italic;
    color: var(--green);
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-bottom: 64px;
  }

  @media (min-width: 768px) {
    .reviews-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .review-card {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: box-shadow 0.3s ease, transform 0.3s var(--ease-out-expo);
  }

  @media (hover: hover) {
    .review-card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-3px);
    }
  }

  .review-stars {
    color: var(--gold);
    font-size: 0.95rem;
    letter-spacing: 2px;
  }

  .review-quote {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    line-height: 1.6;
    flex: 1;
    letter-spacing: -0.005em;
  }

  .review-footer {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 16px;
    border-top: 1px solid var(--line);
  }

  .review-author {
    font-style: normal;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: 0.02em;
  }

  .review-meta {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 400;
  }

  /* Trust bar */
  .trust-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
    padding: 40px;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    flex-wrap: wrap;
  }

  .trust-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-align: center;
  }

  .trust-num {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.03em;
  }

  .trust-label {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .trust-divider {
    width: 1px;
    height: 44px;
    background: var(--line);
  }

  @media (max-width: 640px) {
    .trust-row {
      gap: 32px;
    }
    .trust-divider {
      display: none;
    }
  }
</style>
