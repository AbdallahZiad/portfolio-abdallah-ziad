---
const cols = [
  {
    heading: "Shop",
    links: ["All Products", "Serums", "Oils & Essences", "SPF & Sun", "Masks & Treatments", "Bundles"],
  },
  {
    heading: "About",
    links: ["Our Story", "The Philosophy", "Ingredient Glossary", "Sustainability", "Press"],
  },
  {
    heading: "Support",
    links: ["FAQ", "Track Your Order", "Returns", "Contact Us", "Loyalty Program"],
  },
  {
    heading: "Legal",
    links: ["Privacy Policy", "Terms of Service", "Cookie Settings", "Accessibility"],
  },
];
---

<footer class="footer" role="contentinfo">
  <div class="footer-inner">
    <!-- Brand top -->
    <div class="footer-brand">
      <a href="#" class="footer-logo" aria-label="Aurelia — home">Aurelia</a>
      <p class="footer-tagline">
        Clean, clinically-considered formulas made with cold-pressed botanicals.
        <br/>For skin that looks like skin, only better.
      </p>
      <!-- Social icons -->
      <div class="footer-socials" aria-label="Social media">
        <a href="#" class="social-link" aria-label="Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a href="#" class="social-link" aria-label="Pinterest">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.77 1.2-5.08 1.2-5.08s-.31-.61-.31-1.51c0-1.42.82-2.47 1.84-2.47.87 0 1.29.65 1.29 1.44 0 .88-.56 2.19-.85 3.41-.24 1.02.51 1.84 1.5 1.84 1.8 0 3.19-1.9 3.19-4.64 0-2.42-1.74-4.12-4.23-4.12-2.88 0-4.57 2.16-4.57 4.39 0 .87.33 1.79.75 2.3.08.1.09.19.07.29-.08.32-.25 1.02-.28 1.16-.04.19-.14.23-.32.14-1.19-.55-1.93-2.3-1.93-3.7 0-3 2.18-5.76 6.29-5.76 3.3 0 5.87 2.35 5.87 5.49 0 3.27-2.07 5.91-4.93 5.91-.96 0-1.87-.5-2.18-1.09l-.59 2.22c-.21.82-.79 1.84-1.18 2.46.89.28 1.83.43 2.8.43C17.52 22 22 17.52 22 12S17.52 2 12 2z"/>
          </svg>
        </a>
        <a href="#" class="social-link" aria-label="TikTok">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Nav columns -->
    <nav class="footer-nav" aria-label="Footer navigation">
      {cols.map(col => (
        <div class="footer-col">
          <h3 class="footer-col-heading">{col.heading}</h3>
          <ul role="list">
            {col.links.map(link => (
              <li><a href="#" class="footer-link">{link}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="footer-copyright">© 2026 Aurelia — <em>Concept demo</em></p>
      <p class="footer-made">Crafted with care. Formulated with restraint.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    color: rgba(247, 243, 236, 0.65);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 72px 24px 56px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
  }

  @media (min-width: 900px) {
    .footer-inner {
      grid-template-columns: 300px 1fr;
      gap: 80px;
    }
  }

  /* Brand */
  .footer-logo {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 500;
    font-style: italic;
    color: rgba(247, 243, 236, 0.92);
    letter-spacing: -0.02em;
    margin-bottom: 14px;
    transition: color 0.2s ease;
  }

  @media (hover: hover) {
    .footer-logo:hover {
      color: var(--gold);
    }
  }

  .footer-tagline {
    font-size: 0.86rem;
    line-height: 1.7;
    color: rgba(247, 243, 236, 0.45);
    font-weight: 300;
    margin-bottom: 24px;
    max-width: 280px;
  }

  .footer-socials {
    display: flex;
    gap: 8px;
  }

  .social-link {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(247,243,236,0.14);
    border-radius: var(--radius-sm);
    color: rgba(247,243,236,0.55);
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }

  @media (hover: hover) {
    .social-link:hover {
      border-color: var(--gold);
      color: var(--gold);
      background: rgba(176,137,74,0.08);
    }
  }

  /* Footer nav */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px 24px;
  }

  @media (min-width: 640px) {
    .footer-nav {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .footer-col-heading {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(247, 243, 236, 0.50);
    margin-bottom: 18px;
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-link {
    font-size: 0.86rem;
    color: rgba(247, 243, 236, 0.55);
    font-weight: 400;
    transition: color 0.2s ease;
  }

  @media (hover: hover) {
    .footer-link:hover {
      color: rgba(247, 243, 236, 0.90);
    }
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(247,243,236,0.08);
  }

  .footer-bottom-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .footer-copyright {
    font-size: 0.76rem;
    color: rgba(247,243,236,0.38);
  }

  .footer-copyright em {
    font-style: italic;
    color: rgba(176,137,74,0.65);
  }

  .footer-made {
    font-size: 0.74rem;
    color: rgba(247,243,236,0.28);
    font-style: italic;
    font-family: var(--font-serif);
  }
</style>
