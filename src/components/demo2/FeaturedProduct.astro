---
---
<section class="featured" aria-labelledby="featured-heading">
  <div class="featured-inner">
    <!-- Big bottle visual -->
    <div class="featured-visual reveal" aria-hidden="true">
      <div class="featured-bg-circle"></div>
      <svg class="featured-bottle" viewBox="0 0 180 380" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Midnight Renewal Serum — large view">
        <defs>
          <linearGradient id="f-bottle-grad" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#b89360" stop-opacity="0.38"/>
            <stop offset="30%" stop-color="#e8d5ab" stop-opacity="0.58"/>
            <stop offset="65%" stop-color="#c8a870" stop-opacity="0.42"/>
            <stop offset="100%" stop-color="#8e6c3a" stop-opacity="0.32"/>
          </linearGradient>
          <linearGradient id="f-liquid" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#d4a85e" stop-opacity="0.65"/>
            <stop offset="100%" stop-color="#8a5c28" stop-opacity="0.80"/>
          </linearGradient>
          <linearGradient id="f-cap" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#7a5528"/>
            <stop offset="50%" stop-color="#c49038"/>
            <stop offset="100%" stop-color="#6a4a20"/>
          </linearGradient>
          <linearGradient id="f-highlight" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="white" stop-opacity="0"/>
            <stop offset="28%" stop-color="white" stop-opacity="0.50"/>
            <stop offset="55%" stop-color="white" stop-opacity="0.18"/>
            <stop offset="100%" stop-color="white" stop-opacity="0"/>
          </linearGradient>
          <clipPath id="f-clip">
            <path d="M50 112 C42 115, 32 126, 32 138 L32 330 C32 346, 40 352, 90 352 C140 352, 148 346, 148 330 L148 138 C148 126, 138 115, 130 112 Z"/>
          </clipPath>
          <filter id="f-glow">
            <feGaussianBlur stdDeviation="14" result="blur"/>
            <feComposite in="SourceGraphic" in2="blur" operator="over"/>
          </filter>
        </defs>

        <!-- Glow orb behind bottle -->
        <ellipse cx="90" cy="230" rx="70" ry="90" fill="rgba(176,137,74,0.10)" filter="url(#f-glow)"/>

        <!-- Shadow -->
        <ellipse cx="90" cy="360" rx="44" ry="10" fill="rgba(176,137,74,0.20)"/>

        <!-- Main body -->
        <path d="M50 112 C42 115, 32 126, 32 138 L32 330 C32 346, 40 352, 90 352 C140 352, 148 346, 148 330 L148 138 C148 126, 138 115, 130 112 Z"
          fill="url(#f-bottle-grad)" stroke="#c9a86c" stroke-width="1.4"/>

        <!-- Liquid fill -->
        <rect x="33" y="185" width="115" height="166" fill="url(#f-liquid)" clip-path="url(#f-clip)" opacity="0.60"/>

        <!-- Glass highlight -->
        <path d="M54 118 C50 128, 44 145, 44 178 L44 335" stroke="url(#f-highlight)" stroke-width="7" stroke-linecap="round" opacity="0.85"/>

        <!-- Label -->
        <rect x="42" y="148" width="96" height="122" rx="4" fill="rgba(247,243,236,0.82)" stroke="rgba(176,137,74,0.28)" stroke-width="0.9"/>

        <text x="90" y="174" text-anchor="middle" font-family="Georgia, serif" font-size="13" font-style="italic" fill="#38452f" letter-spacing="0.5">Aurelia</text>
        <line x1="55" y1="180" x2="125" y2="180" stroke="#b0894a" stroke-width="0.7" opacity="0.55"/>
        <text x="90" y="197" text-anchor="middle" font-family="Georgia, serif" font-size="8.5" fill="#221f1a" letter-spacing="2">MIDNIGHT</text>
        <text x="90" y="210" text-anchor="middle" font-family="Georgia, serif" font-size="8.5" fill="#221f1a" letter-spacing="2">RENEWAL</text>
        <line x1="68" y1="217" x2="112" y2="217" stroke="#b0894a" stroke-width="0.6" opacity="0.45"/>
        <text x="90" y="229" text-anchor="middle" font-family="Georgia, serif" font-size="7" fill="#6b6459" letter-spacing="1">OVERNIGHT SERUM</text>
        <text x="90" y="256" text-anchor="middle" font-family="Georgia, serif" font-size="6.5" fill="#6b6459" letter-spacing="0.5">2% Retinal · Bakuchiol · Squalane</text>
        <text x="90" y="270" text-anchor="middle" font-family="Georgia, serif" font-size="6" fill="#6b6459" letter-spacing="0.3">30 ml / 1 fl oz</text>

        <!-- Shoulder / neck -->
        <path d="M50 112 C44 96, 60 80, 70 65 L70 44 L110 44 L110 65 C120 80, 136 96, 130 112 Z"
          fill="url(#f-bottle-grad)" stroke="#c9a86c" stroke-width="1.4"/>
        <path d="M60 106 C57 94, 62 82, 72 68 L74 46" stroke="white" stroke-width="4" stroke-linecap="round" opacity="0.30"/>

        <!-- Cap -->
        <rect x="68" y="15" width="44" height="34" rx="5" fill="url(#f-cap)"/>
        <rect x="72" y="17" width="8" height="30" rx="4" fill="white" opacity="0.16"/>
        <!-- Dropper bulb -->
        <ellipse cx="90" cy="12" rx="12" ry="8" fill="#8a6535"/>
        <ellipse cx="86" cy="9" rx="4" ry="2.5" fill="white" opacity="0.28"/>
        <!-- Gold collar -->
        <rect x="66" y="42" width="48" height="7" rx="2" fill="#c9963e"/>
        <rect x="69" y="43.5" width="10" height="4" rx="1.5" fill="white" opacity="0.22"/>

        <!-- Small decoration circles (bubbles of active ingredients) -->
        <circle cx="145" cy="260" r="4" fill="#c9a86c" fill-opacity="0.22" stroke="#b0894a" stroke-width="0.8"/>
        <circle cx="155" cy="240" r="2.5" fill="#c9a86c" fill-opacity="0.18"/>
        <circle cx="28" cy="200" r="3" fill="#6f7d5f" fill-opacity="0.20" stroke="#6f7d5f" stroke-width="0.7"/>
        <circle cx="20" cy="220" r="2" fill="#6f7d5f" fill-opacity="0.15"/>
      </svg>

      <!-- Floating ingredient badges -->
      <div class="ingredient-badge b1">2% Retinal</div>
      <div class="ingredient-badge b2">Bakuchiol</div>
      <div class="ingredient-badge b3">Squalane</div>
    </div>

    <!-- Product info -->
    <div class="featured-info">
      <span class="featured-eyebrow reveal">Bestseller · No. 01</span>
      <h2 class="featured-name reveal delay-1" id="featured-heading">Meet the Midnight<br/><em>Renewal Serum</em></h2>

      <!-- Stars -->
      <div class="featured-stars reveal delay-2" aria-label="5 out of 5 stars, 312 reviews">
        <span class="stars" aria-hidden="true">★★★★★</span>
        <span class="reviews-count">312 reviews</span>
      </div>

      <p class="featured-desc reveal delay-2">
        A weightless overnight serum with 2% encapsulated retinal, bakuchiol,
        and squalane. Wake to visibly smoother, calmer skin — without the
        irritation of traditional retinoids.
      </p>

      <!-- Badges -->
      <div class="featured-badges reveal delay-3" role="list" aria-label="Product attributes">
        <span class="badge" role="listitem">Vegan</span>
        <span class="badge" role="listitem">Fragrance-free</span>
        <span class="badge" role="listitem">Dermatologist-tested</span>
      </div>

      <!-- Price + CTA -->
      <div class="featured-purchase reveal delay-4">
        <div class="featured-price">$86</div>
        <button class="btn-add-to-bag" data-product="Midnight Renewal Serum" aria-label="Add Midnight Renewal Serum to bag">
          <span class="btn-label">Add to bag</span>
          <span class="btn-confirm" aria-hidden="true">Added ✓</span>
        </button>
      </div>

      <p class="featured-shipping reveal delay-4">Free shipping on orders over $75 · Earn points with every purchase</p>
    </div>
  </div>
</section>

<style>
  .featured {
    padding: 100px 24px;
    background: var(--bg);
    border-top: 1px solid var(--line);
  }

  .featured-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 64px;
    align-items: center;
  }

  @media (min-width: 900px) {
    .featured-inner {
      grid-template-columns: 1fr 1fr;
      gap: 80px;
    }
  }

  /* Visual */
  .featured-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 440px;
  }

  .featured-bg-circle {
    position: absolute;
    width: 340px;
    height: 340px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--bg-2) 0%, transparent 70%);
    pointer-events: none;
  }

  .featured-bottle {
    width: 200px;
    height: auto;
    position: relative;
    z-index: 2;
    filter: drop-shadow(0 32px 56px rgba(176,137,74,0.26));
    transition: transform 0.6s var(--ease-out-expo);
  }

  @media (hover: hover) {
    .featured-visual:hover .featured-bottle {
      transform: translateY(-8px) scale(1.02);
    }
  }

  .ingredient-badge {
    position: absolute;
    background: rgba(247,243,236,0.95);
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    padding: 7px 14px;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--green);
    letter-spacing: 0.04em;
    box-shadow: var(--shadow-sm);
    pointer-events: none;
    backdrop-filter: blur(8px);
  }

  .b1 { top: 15%; right: 2%; }
  .b2 { top: 42%; left: 2%; }
  .b3 { bottom: 22%; right: 5%; }

  /* Info */
  .featured-eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .featured-name {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 20px;
  }

  .featured-name em {
    font-style: italic;
    color: var(--green);
  }

  .featured-stars {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 24px;
  }

  .stars {
    color: var(--gold);
    font-size: 1rem;
    letter-spacing: 2px;
  }

  .reviews-count {
    font-size: 0.78rem;
    color: var(--muted);
    font-weight: 500;
    border-bottom: 1px solid var(--line);
    padding-bottom: 1px;
  }

  .featured-desc {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--muted);
    margin-bottom: 28px;
    font-weight: 300;
  }

  .featured-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 36px;
  }

  .badge {
    display: inline-block;
    padding: 5px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.04em;
    background: var(--bg-2);
  }

  .featured-purchase {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 16px;
  }

  .featured-price {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .btn-add-to-bag {
    position: relative;
    background: var(--green);
    color: #f7f3ec;
    padding: 14px 32px;
    border-radius: var(--radius-pill);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    overflow: hidden;
    transition: background 0.25s ease, transform 0.25s var(--ease-out-expo), box-shadow 0.25s ease;
    box-shadow: 0 2px 16px rgba(56,69,47,0.20);
  }

  @media (hover: hover) {
    .btn-add-to-bag:hover {
      background: var(--ink);
      transform: translateY(-2px);
      box-shadow: 0 6px 28px rgba(34,31,26,0.24);
    }
  }

  .btn-confirm {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--sage);
    transform: translateY(100%);
    transition: transform 0.3s var(--ease-out-expo);
  }

  .btn-add-to-bag.added .btn-confirm {
    transform: translateY(0);
  }

  .btn-add-to-bag.added .btn-label {
    opacity: 0;
  }

  .featured-shipping {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 400;
  }
</style>
