---
---
<section class="pricing-section" id="pricing" aria-labelledby="pricing-heading">
  <div class="pricing-inner">
    <div class="section-header reveal">
      <div class="section-eyebrow">Pricing</div>
      <h2 id="pricing-heading" class="section-title">Simple, transparent pricing.</h2>
      <p class="section-sub">Start free. Scale when you're ready. No surprise bills.</p>
    </div>

    <div class="pricing-grid">
      <!-- Starter -->
      <article class="pricing-card reveal delay-1" aria-labelledby="plan-starter">
        <div class="plan-header">
          <h3 class="plan-name" id="plan-starter">Starter</h3>
          <div class="plan-price">
            <span class="price-amount">$0</span>
            <span class="price-period">/mo</span>
          </div>
          <p class="plan-desc">For side projects &amp; early teams</p>
        </div>
        <ul class="plan-features" role="list">
          <li class="plan-feature"><span class="check" aria-hidden="true">✓</span> Up to 100k events / mo</li>
          <li class="plan-feature"><span class="check" aria-hidden="true">✓</span> 3 seats</li>
          <li class="plan-feature"><span class="check" aria-hidden="true">✓</span> Community support</li>
          <li class="plan-feature"><span class="check" aria-hidden="true">✓</span> Basic dashboards</li>
          <li class="plan-feature muted"><span class="x-icon" aria-hidden="true">×</span> AI queries</li>
          <li class="plan-feature muted"><span class="x-icon" aria-hidden="true">×</span> Alerts</li>
        </ul>
        <a href="#" class="plan-cta plan-cta-ghost" role="button">Start free</a>
      </article>

      <!-- Growth (featured) -->
      <article class="pricing-card pricing-featured reveal delay-2" aria-labelledby="plan-growth">
        <div class="featured-badge">Most popular</div>
        <div class="plan-header">
          <h3 class="plan-name" id="plan-growth">Growth</h3>
          <div class="plan-price">
            <span class="price-amount">$299</span>
            <span class="price-period">/mo</span>
          </div>
          <p class="plan-desc">For scaling product teams</p>
        </div>
        <ul class="plan-features" role="list">
          <li class="plan-feature"><span class="check check-bright" aria-hidden="true">✓</span> 10M events / mo</li>
          <li class="plan-feature"><span class="check check-bright" aria-hidden="true">✓</span> Unlimited seats</li>
          <li class="plan-feature"><span class="check check-bright" aria-hidden="true">✓</span> AI queries</li>
          <li class="plan-feature"><span class="check check-bright" aria-hidden="true">✓</span> Smart alerts</li>
          <li class="plan-feature"><span class="check check-bright" aria-hidden="true">✓</span> Priority support</li>
          <li class="plan-feature"><span class="check check-bright" aria-hidden="true">✓</span> Custom dashboards</li>
        </ul>
        <a href="#" class="plan-cta plan-cta-primary" role="button">Start free</a>
      </article>

      <!-- Enterprise -->
      <article class="pricing-card reveal delay-3" aria-labelledby="plan-enterprise">
        <div class="plan-header">
          <h3 class="plan-name" id="plan-enterprise">Enterprise</h3>
          <div class="plan-price">
            <span class="price-amount price-custom">Custom</span>
          </div>
          <p class="plan-desc">For scale &amp; compliance</p>
        </div>
        <ul class="plan-features" role="list">
          <li class="plan-feature"><span class="check" aria-hidden="true">✓</span> SSO / SAML</li>
          <li class="plan-feature"><span class="check" aria-hidden="true">✓</span> SOC 2 Type II</li>
          <li class="plan-feature"><span class="check" aria-hidden="true">✓</span> Dedicated infra</li>
          <li class="plan-feature"><span class="check" aria-hidden="true">✓</span> 99.99% SLA</li>
          <li class="plan-feature"><span class="check" aria-hidden="true">✓</span> Custom contracts</li>
          <li class="plan-feature"><span class="check" aria-hidden="true">✓</span> White-glove onboarding</li>
        </ul>
        <a href="#" class="plan-cta plan-cta-ghost" role="button">Contact sales</a>
      </article>
    </div>
  </div>
</section>

<style>
  .pricing-section {
    padding: 6rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .pricing-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 400px;
    background: radial-gradient(ellipse at center top, rgba(139, 92, 246, 0.1) 0%, transparent 60%);
    filter: blur(40px);
    pointer-events: none;
  }

  .pricing-inner {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--violet-2);
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.25);
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
  }

  .section-title {
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .section-sub {
    font-size: 1rem;
    color: var(--muted);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .pricing-grid {
      grid-template-columns: repeat(3, 1fr);
      align-items: stretch;
    }
  }

  .pricing-card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  @media (min-width: 1024px) {
    .pricing-card {
      padding: 2rem;
      gap: 1.75rem;
    }
  }

  @media (hover: hover) {
    .pricing-card:hover {
      border-color: var(--border-2);
    }
  }

  .pricing-featured {
    border-color: rgba(139, 92, 246, 0.4);
    background: rgba(139, 92, 246, 0.05);
    box-shadow: 0 0 60px rgba(139, 92, 246, 0.12), var(--shadow-elevated);
  }

  .pricing-featured::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--grad-primary);
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  }

  @media (hover: hover) {
    .pricing-featured:hover {
      border-color: rgba(139, 92, 246, 0.6);
    }
  }

  .featured-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: white;
    background: var(--grad-primary);
    padding: 0.3rem 0.9rem;
    border-radius: 100px;
    box-shadow: 0 0 16px rgba(139, 92, 246, 0.4);
  }

  .plan-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .plan-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
  }

  .plan-price {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }

  .price-amount {
    font-family: var(--font-head);
    font-size: 2.75rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.04em;
  }

  .price-custom {
    font-size: 1.75rem;
  }

  .price-period {
    font-size: 0.875rem;
    color: var(--muted);
  }

  .plan-desc {
    font-size: 0.875rem;
    color: var(--muted);
  }

  .plan-features {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    flex: 1;
  }

  .plan-feature {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.875rem;
    color: var(--text);
  }

  .plan-feature.muted {
    color: var(--muted-2);
  }

  .check {
    color: #34d399;
    font-weight: 700;
    flex-shrink: 0;
  }

  .check-bright {
    color: var(--violet-2);
  }

  .x-icon {
    color: var(--muted-2);
    font-size: 1rem;
    flex-shrink: 0;
  }

  .plan-cta {
    display: block;
    text-align: center;
    padding: 0.8rem 1rem;
    font-size: 0.925rem;
    font-weight: 600;
    border-radius: var(--radius-md);
    transition: opacity 0.2s, box-shadow 0.2s, background 0.2s;
  }

  .plan-cta-ghost {
    color: var(--text);
    border: 1px solid var(--border-2);
    background: transparent;
  }

  @media (hover: hover) {
    .plan-cta-ghost:hover {
      background: var(--surface-2);
    }
  }

  .plan-cta-primary {
    color: white;
    background: var(--grad-primary);
    box-shadow: 0 0 24px rgba(139, 92, 246, 0.3);
  }

  @media (hover: hover) {
    .plan-cta-primary:hover {
      opacity: 0.9;
      box-shadow: 0 0 36px rgba(139, 92, 246, 0.45);
    }
  }
</style>
