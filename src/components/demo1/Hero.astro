---
---
<section class="hero" aria-label="Hero section">
  <!-- Aurora background glows -->
  <div class="aurora-1" aria-hidden="true"></div>
  <div class="aurora-2" aria-hidden="true"></div>
  <div class="aurora-3" aria-hidden="true"></div>
  <div class="grid-overlay" aria-hidden="true"></div>

  <div class="hero-inner">
    <div class="hero-content reveal">
      <div class="eyebrow">AI-NATIVE PRODUCT ANALYTICS</div>
      <h1 class="hero-headline">
        Understand your product.<br />
        <span class="grad-text">Instantly.</span>
      </h1>
      <p class="hero-subhead">
        Nebula unifies your events, funnels, and revenue into one AI workspace
        — ask a question in plain English, get an answer backed by your data.
      </p>
      <div class="hero-ctas">
        <a href="#" class="cta-primary" role="button">
          Start free
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#" class="cta-secondary" role="button">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2"/>
            <path d="M6.5 5.5L11 8L6.5 10.5V5.5Z" fill="currentColor"/>
          </svg>
          Book a demo
        </a>
      </div>
      <p class="trust-line">
        <span>No credit card required</span>
        <span class="dot" aria-hidden="true">·</span>
        <span>SOC 2 Type II</span>
        <span class="dot" aria-hidden="true">·</span>
        <span>Setup in under 10 minutes</span>
      </p>
    </div>

    <!-- Dashboard mockup -->
    <div class="dashboard-wrap reveal delay-2">
      <div class="dashboard-card" role="img" aria-label="Nebula analytics dashboard mockup">
        <!-- Dashboard header -->
        <div class="dash-header">
          <div class="dash-title">
            <span class="dash-dot dot-red" aria-hidden="true"></span>
            <span class="dash-dot dot-amber" aria-hidden="true"></span>
            <span class="dash-dot dot-green" aria-hidden="true"></span>
            <span class="dash-label">nebula.app / overview</span>
          </div>
          <div class="dash-date">Jul 2026</div>
        </div>

        <!-- KPI tiles -->
        <div class="kpi-row">
          <div class="kpi-tile">
            <div class="kpi-label">Monthly Active Users</div>
            <div class="kpi-value">
              <span class="count-up" data-target="48200" data-prefix="" data-suffix="k" data-divisor="1000">0k</span>
              <span class="kpi-badge up">▲ 12%</span>
            </div>
          </div>
          <div class="kpi-tile">
            <div class="kpi-label">Retention (D30)</div>
            <div class="kpi-value">
              <span class="count-up" data-target="63" data-prefix="" data-suffix="%">0%</span>
              <span class="kpi-badge neutral">→ 0.5%</span>
            </div>
          </div>
          <div class="kpi-tile">
            <div class="kpi-label">Revenue (MRR)</div>
            <div class="kpi-value">
              <span class="count-up" data-target="1.2" data-prefix="$" data-suffix="M" data-decimal="true">$0M</span>
              <span class="kpi-badge up">▲ 8%</span>
            </div>
          </div>
        </div>

        <!-- Charts row -->
        <div class="charts-row">
          <!-- Animated line chart -->
          <div class="chart-card line-chart-wrap">
            <div class="chart-title">MAU Growth</div>
            <svg class="line-chart" viewBox="0 0 280 100" fill="none" aria-label="MAU growth line chart" role="img">
              <defs>
                <linearGradient id="lineGrad" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%" stop-color="#6366f1"/>
                  <stop offset="100%" stop-color="#ec4899"/>
                </linearGradient>
                <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#8b5cf6" stop-opacity="0.3"/>
                  <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0"/>
                </linearGradient>
                <clipPath id="lineClip">
                  <rect id="line-clip-rect" x="0" y="0" width="0" height="100"/>
                </clipPath>
              </defs>
              <!-- Grid lines -->
              <line x1="0" y1="25" x2="280" y2="25" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
              <line x1="0" y1="50" x2="280" y2="50" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
              <line x1="0" y1="75" x2="280" y2="75" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
              <!-- Area fill (clipped) -->
              <path class="area-path" d="M0 85 L35 75 L70 68 L105 60 L140 52 L175 42 L210 30 L245 20 L280 12 L280 100 L0 100 Z" fill="url(#areaGrad)" clip-path="url(#lineClip)"/>
              <!-- Line (clipped) -->
              <path class="line-path" d="M0 85 L35 75 L70 68 L105 60 L140 52 L175 42 L210 30 L245 20 L280 12" stroke="url(#lineGrad)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" clip-path="url(#lineClip)"/>
              <!-- Data points -->
              <g class="data-points" clip-path="url(#lineClip)">
                <circle cx="0" cy="85" r="3" fill="#8b5cf6"/>
                <circle cx="70" cy="68" r="3" fill="#8b5cf6"/>
                <circle cx="140" cy="52" r="3" fill="#8b5cf6"/>
                <circle cx="210" cy="30" r="3" fill="#ec4899"/>
                <circle cx="280" cy="12" r="3" fill="#ec4899"/>
              </g>
              <!-- Labels -->
              <text x="0" y="98" fill="rgba(160,156,192,0.7)" font-size="8" font-family="Inter,sans-serif">Jan</text>
              <text x="65" y="98" fill="rgba(160,156,192,0.7)" font-size="8" font-family="Inter,sans-serif">Mar</text>
              <text x="130" y="98" fill="rgba(160,156,192,0.7)" font-size="8" font-family="Inter,sans-serif">May</text>
              <text x="195" y="98" fill="rgba(160,156,192,0.7)" font-size="8" font-family="Inter,sans-serif">Jun</text>
              <text x="260" y="98" fill="rgba(160,156,192,0.7)" font-size="8" font-family="Inter,sans-serif">Jul</text>
            </svg>
          </div>

          <!-- Bar chart -->
          <div class="chart-card bar-chart-wrap">
            <div class="chart-title">Daily Active</div>
            <svg class="bar-chart" viewBox="0 0 100 80" fill="none" aria-label="Daily active users bar chart" role="img">
              <defs>
                <linearGradient id="barGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#8b5cf6"/>
                  <stop offset="100%" stop-color="#6366f1"/>
                </linearGradient>
                <linearGradient id="barGradHi" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#ec4899"/>
                  <stop offset="100%" stop-color="#8b5cf6"/>
                </linearGradient>
              </defs>
              <rect x="4" y="50" width="10" height="24" rx="2" fill="url(#barGrad)" opacity="0.7"/>
              <rect x="17" y="38" width="10" height="36" rx="2" fill="url(#barGrad)" opacity="0.7"/>
              <rect x="30" y="44" width="10" height="30" rx="2" fill="url(#barGrad)" opacity="0.7"/>
              <rect x="43" y="30" width="10" height="44" rx="2" fill="url(#barGrad)" opacity="0.85"/>
              <rect x="56" y="20" width="10" height="54" rx="2" fill="url(#barGradHi)"/>
              <rect x="69" y="26" width="10" height="48" rx="2" fill="url(#barGrad)" opacity="0.85"/>
              <rect x="82" y="15" width="10" height="59" rx="2" fill="url(#barGradHi)"/>
            </svg>
          </div>
        </div>

        <!-- AI query row -->
        <div class="ai-row">
          <div class="ai-input-wrap">
            <span class="ai-sparkle" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M7 1L8.5 5.5L13 7L8.5 8.5L7 13L5.5 8.5L1 7L5.5 5.5L7 1Z" fill="#8b5cf6"/>
              </svg>
            </span>
            <span class="ai-query">Why did activation drop last week?</span>
            <span class="ai-enter" aria-hidden="true">⏎</span>
          </div>
          <div class="ai-answer-chip">
            <span class="ai-chip-dot" aria-hidden="true"></span>
            Activation fell 11% after the onboarding change on June 3 — step 3 drop-off ▲34%
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 7rem 1.5rem 5rem;
  }

  /* Aurora glows */
  .aurora-1 {
    position: absolute;
    top: -20%;
    left: -10%;
    width: 70vw;
    height: 70vw;
    max-width: 700px;
    max-height: 700px;
    background: radial-gradient(ellipse at center, rgba(99, 102, 241, 0.22) 0%, transparent 70%);
    filter: blur(60px);
    pointer-events: none;
  }

  .aurora-2 {
    position: absolute;
    top: 10%;
    right: -15%;
    width: 60vw;
    height: 60vw;
    max-width: 600px;
    max-height: 600px;
    background: radial-gradient(ellipse at center, rgba(236, 72, 153, 0.18) 0%, transparent 70%);
    filter: blur(70px);
    pointer-events: none;
  }

  .aurora-3 {
    position: absolute;
    bottom: -10%;
    left: 30%;
    width: 50vw;
    height: 50vw;
    max-width: 500px;
    max-height: 500px;
    background: radial-gradient(ellipse at center, rgba(34, 211, 238, 0.1) 0%, transparent 70%);
    filter: blur(80px);
    pointer-events: none;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 0%, black 0%, transparent 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-inner > * { min-width: 0; }

  @media (min-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .hero-content {
    max-width: 560px;
  }

  .eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--violet-2);
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.25);
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }

  .hero-headline {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.05;
    margin-bottom: 1.25rem;
    color: var(--text);
  }

  .grad-text {
    background: var(--grad-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subhead {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--muted);
    margin-bottom: 2rem;
    max-width: 480px;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: #fff;
    background: var(--grad-primary);
    border-radius: var(--radius-md);
    box-shadow: 0 0 30px rgba(139, 92, 246, 0.35), 0 4px 16px rgba(0, 0, 0, 0.3);
    transition: box-shadow 0.2s, opacity 0.2s;
  }

  @media (hover: hover) {
    .cta-primary:hover {
      opacity: 0.9;
      box-shadow: 0 0 40px rgba(139, 92, 246, 0.5), 0 4px 20px rgba(0, 0, 0, 0.35);
    }
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-md);
    backdrop-filter: blur(10px);
    transition: background 0.2s, border-color 0.2s;
  }

  @media (hover: hover) {
    .cta-secondary:hover {
      background: var(--surface-2);
      border-color: rgba(255,255,255,0.2);
    }
  }

  .trust-line {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--muted-2);
  }

  .dot {
    opacity: 0.4;
  }

  /* Dashboard card */
  .dashboard-wrap {
    perspective: 1200px;
  }

  .dashboard-card {
    background: rgba(13, 10, 31, 0.8);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-xl);
    padding: 1rem;
    box-shadow: var(--shadow-elevated), 0 0 60px rgba(99, 102, 241, 0.1);
    backdrop-filter: blur(20px);
    transform: none;
    transition: transform 0.4s ease;
    overflow: hidden;
    position: relative;
  }

  /* Only apply the 3D tilt on larger screens where the two-column layout appears */
  @media (min-width: 1024px) {
    .dashboard-card {
      padding: 1.25rem;
      transform: perspective(1000px) rotateY(-4deg) rotateX(2deg);
    }
  }

  .dashboard-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.5), rgba(236, 72, 153, 0.5), transparent);
  }

  @media (hover: hover) {
    .dashboard-card:hover {
      transform: perspective(1000px) rotateY(-2deg) rotateX(1deg);
    }
  }

  /* Dashboard header */
  .dash-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .dash-title {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .dash-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot-red { background: #ff5f57; }
  .dot-amber { background: #ffbd2e; }
  .dot-green { background: #28c840; }

  .dash-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted-2);
    margin-left: 0.25rem;
  }

  .dash-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted-2);
  }

  /* KPI row */
  .kpi-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  @media (min-width: 420px) {
    .kpi-row { gap: 0.75rem; }
  }

  .kpi-tile {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.6rem;
    min-width: 0;
    overflow: hidden;
  }

  @media (min-width: 420px) {
    .kpi-tile { padding: 0.75rem; }
  }

  .kpi-label {
    font-size: 0.68rem;
    color: var(--muted-2);
    margin-bottom: 0.35rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .kpi-value {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .kpi-value .count-up {
    font-family: var(--font-head);
    font-size: clamp(0.9rem, 3.8vw, 1.35rem);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.03em;
  }

  .kpi-badge {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    padding: 0.15rem 0.4rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .kpi-badge.up {
    color: #34d399;
    background: rgba(52, 211, 153, 0.12);
  }

  .kpi-badge.neutral {
    color: var(--cyan);
    background: rgba(34, 211, 238, 0.1);
  }

  /* Charts */
  .charts-row {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .chart-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.75rem;
  }

  .chart-title {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--muted);
    margin-bottom: 0.5rem;
    font-family: var(--font-head);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .line-chart, .bar-chart {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  /* AI query row */
  .ai-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ai-input-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(139, 92, 246, 0.07);
    border: 1px solid rgba(139, 92, 246, 0.25);
    border-radius: var(--radius-md);
    padding: 0.6rem 0.8rem;
  }

  .ai-sparkle {
    flex-shrink: 0;
  }

  .ai-query {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text);
    flex: 1;
  }

  .ai-enter {
    font-size: 0.7rem;
    color: var(--muted-2);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .ai-answer-chip {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.72rem;
    color: var(--cyan);
    background: rgba(34, 211, 238, 0.07);
    border: 1px solid rgba(34, 211, 238, 0.2);
    border-radius: var(--radius-md);
    padding: 0.55rem 0.8rem;
    line-height: 1.4;
    overflow-wrap: break-word;
    word-break: break-word;
    min-width: 0;
  }

  .ai-chip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cyan);
    flex-shrink: 0;
    animation: pulse-dot 2s ease infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-chip-dot { animation: none; }
  }

  /* ---- Mobile dashboard scaling ---- */
  @media (max-width: 640px) {
    .dashboard-card { padding: 0.75rem; }
    .dash-label { max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .kpi-tile { padding: 0.5rem 0.4rem; }
    .kpi-label { font-size: 0.58rem; line-height: 1.25; }
    .kpi-value .count-up { font-size: 0.88rem; }
    .kpi-badge { font-size: 0.54rem; padding: 0.1rem 0.28rem; }
    .chart-card { padding: 0.5rem; }
    .chart-title { font-size: 0.6rem; margin-bottom: 0.3rem; }
    .ai-input-wrap { padding: 0.45rem 0.6rem; gap: 0.35rem; }
    .ai-query { font-size: 0.64rem; }
    .ai-enter { display: none; }
    .ai-answer-chip { font-size: 0.64rem; padding: 0.45rem 0.6rem; }
  }

  @media (max-width: 400px) {
    .kpi-badge { display: none; }
    .bar-chart-wrap { display: none; }
    .charts-row { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  // Animate SVG line chart on load
  (function () {
    function animateChart() {
      var rect = document.getElementById('line-clip-rect');
      if (!rect) return;

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        rect.setAttribute('width', '280');
        return;
      }

      var start = null;
      var duration = 1600;

      function step(ts) {
        if (!start) start = ts;
        var progress = Math.min((ts - start) / duration, 1);
        // ease out cubic
        var eased = 1 - Math.pow(1 - progress, 3);
        rect.setAttribute('width', String(280 * eased));
        if (progress < 1) requestAnimationFrame(step);
      }

      requestAnimationFrame(step);
    }

    // Count up numbers
    function countUp(el) {
      var target = parseFloat(el.dataset.target);
      var prefix = el.dataset.prefix || '';
      var suffix = el.dataset.suffix || '';
      var isDecimal = el.dataset.decimal === 'true';
      var divisor = el.dataset.divisor ? parseFloat(el.dataset.divisor) : 1;
      var duration = 1400;
      var start = null;

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        var finalVal = isDecimal ? target.toFixed(1) : Math.round(target / divisor);
        el.textContent = prefix + finalVal + suffix;
        return;
      }

      function step(ts) {
        if (!start) start = ts;
        var progress = Math.min((ts - start) / duration, 1);
        var eased = 1 - Math.pow(1 - progress, 3);
        var current = target * eased;
        var display;
        if (isDecimal) {
          display = current.toFixed(1);
        } else {
          display = Math.round(current / divisor);
        }
        el.textContent = prefix + display + suffix;
        if (progress < 1) requestAnimationFrame(step);
      }

      requestAnimationFrame(step);
    }

    // IntersectionObserver for hero
    var hero = document.querySelector('.hero');
    if (!hero) return;

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          animateChart();
          document.querySelectorAll('.count-up').forEach(countUp);
          observer.disconnect();
        }
      });
    }, { threshold: 0.2 });

    observer.observe(hero);
  })();
</script>
