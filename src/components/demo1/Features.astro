---
---
<section class="features-section" id="features" aria-labelledby="features-heading">
  <div class="features-inner">
    <div class="section-header reveal">
      <div class="section-eyebrow">Features</div>
      <h2 id="features-heading" class="section-title">Everything you need to<br/><span class="grad-text">understand your product.</span></h2>
    </div>

    <div class="bento-grid" aria-label="Feature list">
      <!-- Large tile: Ask in plain English -->
      <article class="bento-tile bento-large reveal" aria-labelledby="feat-1">
        <div class="tile-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <circle cx="14" cy="14" r="13" stroke="url(#f1g)" stroke-width="1.5"/>
            <path d="M8 14h12M14 8l6 6-6 6" stroke="#8b5cf6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <defs>
              <linearGradient id="f1g" x1="1" y1="1" x2="27" y2="27">
                <stop stop-color="#8b5cf6"/><stop offset="1" stop-color="#ec4899"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <h3 class="tile-title" id="feat-1">Ask in plain English</h3>
        <p class="tile-body">Type a question, Nebula writes the query, runs it, and explains the result. No SQL required — just curiosity.</p>
        <!-- Mini demo -->
        <div class="mini-ask" aria-hidden="true">
          <span class="mini-ask-q">What's my best acquisition channel this month?</span>
          <span class="mini-ask-a">Organic search — 2.4k users, 41% activation rate.</span>
        </div>
        <div class="tile-badge">AI</div>
      </article>

      <!-- Live funnels -->
      <article class="bento-tile reveal delay-1" aria-labelledby="feat-2">
        <div class="tile-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect x="4" y="5" width="20" height="4" rx="2" fill="url(#f2g)" opacity="0.9"/>
            <rect x="6" y="12" width="16" height="4" rx="2" fill="url(#f2g)" opacity="0.75"/>
            <rect x="9" y="19" width="10" height="4" rx="2" fill="url(#f2g)" opacity="0.6"/>
            <defs>
              <linearGradient id="f2g" x1="1" y1="1" x2="27" y2="27">
                <stop stop-color="#6366f1"/><stop offset="1" stop-color="#22d3ee"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <h3 class="tile-title" id="feat-2">Live funnels</h3>
        <p class="tile-body">Watch conversion across every step, segmented in real time.</p>
      </article>

      <!-- Retention cohorts -->
      <article class="bento-tile reveal delay-2" aria-labelledby="feat-3">
        <div class="tile-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect x="4" y="4" width="8" height="8" rx="2" fill="url(#f3g)" opacity="0.9"/>
            <rect x="14" y="4" width="8" height="8" rx="2" fill="url(#f3g)" opacity="0.7"/>
            <rect x="4" y="14" width="8" height="8" rx="2" fill="url(#f3g)" opacity="0.5"/>
            <rect x="14" y="14" width="8" height="8" rx="2" fill="url(#f3g)" opacity="0.35"/>
            <defs>
              <linearGradient id="f3g" x1="1" y1="1" x2="27" y2="27">
                <stop stop-color="#8b5cf6"/><stop offset="1" stop-color="#22d3ee"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <h3 class="tile-title" id="feat-3">Retention cohorts</h3>
        <p class="tile-body">See exactly when and why users stick — or slip away. Cohort grids update on every deploy.</p>
      </article>

      <!-- Revenue attribution — medium wide -->
      <article class="bento-tile reveal delay-1" aria-labelledby="feat-4">
        <div class="tile-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <path d="M14 4v20M8 9l6-5 6 5M8 19l6 5 6-5" stroke="url(#f4g)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <defs>
              <linearGradient id="f4g" x1="1" y1="1" x2="27" y2="27">
                <stop stop-color="#ec4899"/><stop offset="1" stop-color="#8b5cf6"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <h3 class="tile-title" id="feat-4">Revenue attribution</h3>
        <p class="tile-body">Connect product behavior to dollars, automatically. Trace any cohort from first touch to expansion revenue.</p>
      </article>

      <!-- Alerts -->
      <article class="bento-tile reveal delay-2" aria-labelledby="feat-5">
        <div class="tile-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <path d="M14 4a7 7 0 0 1 7 7v5l2 3H5l2-3v-5a7 7 0 0 1 7-7z" stroke="url(#f5g)" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M11 22a3 3 0 0 0 6 0" stroke="url(#f5g)" stroke-width="1.5"/>
            <circle cx="14" cy="9" r="2" fill="#ec4899" opacity="0.8"/>
            <defs>
              <linearGradient id="f5g" x1="1" y1="1" x2="27" y2="27">
                <stop stop-color="#ec4899"/><stop offset="1" stop-color="#6366f1"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <h3 class="tile-title" id="feat-5">Alerts that matter</h3>
        <p class="tile-body">Nebula surfaces anomalies before they become incidents.</p>
      </article>

      <!-- Warehouse-native -->
      <article class="bento-tile bento-tablet-wide reveal delay-3" aria-labelledby="feat-6">
        <div class="tile-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect x="4" y="6" width="20" height="16" rx="3" stroke="url(#f6g)" stroke-width="1.5"/>
            <path d="M4 11h20" stroke="url(#f6g)" stroke-width="1.2"/>
            <circle cx="8" cy="8.5" r="1" fill="#22d3ee"/>
            <circle cx="11.5" cy="8.5" r="1" fill="#8b5cf6"/>
            <path d="M8 15h4M8 18h6" stroke="rgba(160,156,192,0.5)" stroke-width="1" stroke-linecap="round"/>
            <defs>
              <linearGradient id="f6g" x1="1" y1="1" x2="27" y2="27">
                <stop stop-color="#22d3ee"/><stop offset="1" stop-color="#6366f1"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <h3 class="tile-title" id="feat-6">Warehouse-native</h3>
        <p class="tile-body">Plug into Postgres, Snowflake, or BigQuery in minutes — Nebula syncs directly, so your data never leaves your stack.</p>
      </article>
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 6rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .features-section::before {
    content: '';
    position: absolute;
    top: 10%;
    right: -20%;
    width: 50vw;
    height: 50vw;
    max-width: 500px;
    max-height: 500px;
    background: radial-gradient(ellipse, rgba(99, 102, 241, 0.1) 0%, transparent 70%);
    filter: blur(80px);
    pointer-events: none;
  }

  .features-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--violet-2);
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.25);
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
  }

  .section-title {
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.12;
  }

  .grad-text {
    background: var(--grad-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Bento grid */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  /* Tablet: 2-up. Large tile + a balancing full-width tile so no card is orphaned. */
  @media (min-width: 600px) and (max-width: 1023px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .bento-large {
      grid-column: span 2;
    }

    /* Warehouse-native fills the trailing row instead of sitting alone */
    .bento-tablet-wide {
      grid-column: span 2;
    }
  }

  /* Desktop: 3-up. large (2x2) + five 1x1 tiles flow into a clean 3-column block. */
  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .bento-large {
      grid-column: span 2;
      grid-row: span 2;
    }
  }

  .bento-tile {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    overflow: hidden;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
  }

  .bento-tile::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.3), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  @media (hover: hover) {
    .bento-tile:hover {
      border-color: var(--border-2);
      box-shadow: 0 8px 32px rgba(0,0,0,0.3), 0 0 20px rgba(139, 92, 246, 0.08);
      transform: translateY(-2px);
    }
    .bento-tile:hover::before {
      opacity: 1;
    }
  }

  .tile-icon {
    margin-bottom: 1.25rem;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(139, 92, 246, 0.08);
    border: 1px solid rgba(139, 92, 246, 0.15);
    border-radius: var(--radius-md);
  }

  .tile-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.6rem;
  }

  .tile-body {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--muted);
  }

  .tile-badge {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--violet-2);
    background: rgba(139, 92, 246, 0.12);
    border: 1px solid rgba(139, 92, 246, 0.3);
    padding: 0.2rem 0.5rem;
    border-radius: 100px;
  }

  /* Mini ask demo */
  .mini-ask {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mini-ask-q {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text);
    background: rgba(139, 92, 246, 0.07);
    border: 1px solid rgba(139, 92, 246, 0.2);
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-sm);
  }

  .mini-ask-q::before {
    content: '⟩';
    color: var(--violet-2);
  }

  .mini-ask-a {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--cyan);
    background: rgba(34, 211, 238, 0.06);
    border: 1px solid rgba(34, 211, 238, 0.15);
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-sm);
  }
</style>
