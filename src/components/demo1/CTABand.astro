---
---
<section class="cta-band" aria-labelledby="cta-heading">
  <div class="cta-aurora-1" aria-hidden="true"></div>
  <div class="cta-aurora-2" aria-hidden="true"></div>
  <div class="cta-inner">
    <h2 id="cta-heading" class="cta-headline reveal">Ship with data on your side.</h2>
    <p class="cta-sub reveal delay-1">Join thousands of product teams who make faster, smarter decisions with Nebula.</p>
    <div class="cta-actions reveal delay-2">
      <a href="#" class="cta-primary" role="button">
        Start free
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#" class="cta-ghost" role="button">Book a demo</a>
    </div>
    <p class="cta-trust reveal delay-3">No credit card required · SOC 2 Type II · Setup in under 10 minutes</p>
  </div>
</section>

<style>
  .cta-band {
    padding: 7rem 1.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--bg-2);
  }

  .cta-aurora-1 {
    position: absolute;
    top: -30%;
    left: -10%;
    width: 60vw;
    height: 60vw;
    max-width: 600px;
    max-height: 600px;
    background: radial-gradient(ellipse, rgba(99, 102, 241, 0.18) 0%, transparent 70%);
    filter: blur(80px);
    pointer-events: none;
  }

  .cta-aurora-2 {
    position: absolute;
    bottom: -30%;
    right: -10%;
    width: 50vw;
    height: 50vw;
    max-width: 500px;
    max-height: 500px;
    background: radial-gradient(ellipse, rgba(236, 72, 153, 0.16) 0%, transparent 70%);
    filter: blur(80px);
    pointer-events: none;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
  }

  .cta-headline {
    font-size: clamp(2.25rem, 5.5vw, 3.5rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--text) 0%, rgba(236, 233, 251, 0.7) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cta-sub {
    font-size: 1.1rem;
    color: var(--muted);
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    color: white;
    background: var(--grad-primary);
    border-radius: var(--radius-md);
    box-shadow: 0 0 40px rgba(139, 92, 246, 0.4), 0 4px 20px rgba(0,0,0,0.3);
    transition: opacity 0.2s, box-shadow 0.2s;
  }

  @media (hover: hover) {
    .cta-primary:hover {
      opacity: 0.9;
      box-shadow: 0 0 60px rgba(139, 92, 246, 0.55), 0 4px 20px rgba(0,0,0,0.3);
    }
  }

  .cta-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 1.75rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-md);
    backdrop-filter: blur(10px);
    transition: background 0.2s;
  }

  @media (hover: hover) {
    .cta-ghost:hover {
      background: var(--surface-2);
    }
  }

  .cta-trust {
    font-size: 0.78rem;
    color: var(--muted-2);
  }
</style>
