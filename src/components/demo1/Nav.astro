---
---
<header class="nav-wrap" role="banner">
  <nav class="nav" aria-label="Main navigation">
    <a href="/" class="portfolio-pill" aria-label="Back to Portfolio">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M9 2L4 7L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Portfolio
    </a>

    <a href="#" class="brand" aria-label="Nebula home">
      <span class="brand-diamond" aria-hidden="true">◆</span>
      <span class="brand-name">Nebula</span>
    </a>

    <ul class="nav-links" role="list">
      <li><a href="#features" class="nav-link">Product</a></li>
      <li><a href="#how-it-works" class="nav-link">Solutions</a></li>
      <li><a href="#pricing" class="nav-link">Pricing</a></li>
      <li><a href="#faq" class="nav-link">Docs</a></li>
    </ul>

    <div class="nav-actions">
      <a href="#" class="btn-ghost">Sign in</a>
      <a href="#" class="btn-primary">Start free</a>
    </div>

    <button class="hamburger" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </nav>

  <div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Mobile navigation">
    <ul role="list">
      <li><a href="#features" class="mobile-link">Product</a></li>
      <li><a href="#how-it-works" class="mobile-link">Solutions</a></li>
      <li><a href="#pricing" class="mobile-link">Pricing</a></li>
      <li><a href="#faq" class="mobile-link">Docs</a></li>
    </ul>
    <div class="mobile-actions">
      <a href="#" class="btn-ghost btn-full">Sign in</a>
      <a href="#" class="btn-primary btn-full">Start free</a>
    </div>
  </div>
</header>

<style>
  .nav-wrap {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(7, 5, 18, 0.75);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid var(--border);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.875rem 1.5rem;
  }

  .portfolio-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.3rem 0.7rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 100px;
    white-space: nowrap;
    transition: color 0.2s, border-color 0.2s;
    flex-shrink: 0;
  }

  @media (hover: hover) {
    .portfolio-pill:hover {
      color: var(--text);
      border-color: var(--border-2);
    }
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
    margin-left: auto;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .brand { margin-left: 1rem; margin-right: auto; }
  }

  .brand-diamond {
    background: var(--grad-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-size: 1rem;
  }

  .brand-name {
    color: var(--text);
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }

  @media (min-width: 900px) {
    .nav-links { display: flex; }
  }

  .nav-link {
    padding: 0.4rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted);
    border-radius: var(--radius-sm);
    transition: color 0.2s, background 0.2s;
  }

  @media (hover: hover) {
    .nav-link:hover {
      color: var(--text);
      background: var(--surface);
    }
  }

  .nav-actions {
    display: none;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  @media (min-width: 900px) {
    .nav-actions { display: flex; }
  }

  .btn-ghost {
    padding: 0.45rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: transparent;
    transition: color 0.2s, border-color 0.2s;
  }

  @media (hover: hover) {
    .btn-ghost:hover {
      color: var(--text);
      border-color: var(--border-2);
    }
  }

  .btn-primary {
    padding: 0.45rem 1.1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
    background: var(--grad-primary);
    border-radius: var(--radius-sm);
    border: none;
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.3);
    transition: opacity 0.2s, box-shadow 0.2s;
  }

  @media (hover: hover) {
    .btn-primary:hover {
      opacity: 0.9;
      box-shadow: 0 0 28px rgba(139, 92, 246, 0.45);
    }
  }

  .btn-full {
    width: 100%;
    text-align: center;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    display: block;
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    margin-left: 0.5rem;
  }

  @media (min-width: 900px) {
    .hamburger { display: none; }
  }

  .hamburger-line {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--muted);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s, background 0.2s;
  }

  .hamburger.is-open .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger.is-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .hamburger.is-open .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 1.5rem 1.5rem;
    border-top: 1px solid var(--border);
  }

  .mobile-menu.is-open {
    display: flex;
  }

  .mobile-link {
    display: block;
    padding: 0.65rem 0.75rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--muted);
    border-radius: var(--radius-sm);
    transition: color 0.2s, background 0.2s;
  }

  @media (hover: hover) {
    .mobile-link:hover {
      color: var(--text);
      background: var(--surface);
    }
  }

  .mobile-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }
</style>

<script is:inline>
  (function () {
    const btn = document.querySelector('.hamburger');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;

    btn.addEventListener('click', function () {
      const isOpen = menu.classList.toggle('is-open');
      btn.classList.toggle('is-open', isOpen);
      btn.setAttribute('aria-expanded', String(isOpen));
      menu.setAttribute('aria-hidden', String(!isOpen));
    });

    // Close on link click
    menu.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', function () {
        menu.classList.remove('is-open');
        btn.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
      });
    });
  })();
</script>
