---
---
<footer class="footer" role="contentinfo">
  <div class="footer-inner">
    <!-- Top: columns -->
    <div class="footer-grid">
      <!-- Brand column -->
      <div class="footer-brand">
        <a href="#" class="brand" aria-label="Nebula home">
          <span class="brand-diamond" aria-hidden="true">◆</span>
          <span class="brand-name">Nebula</span>
        </a>
        <p class="brand-tagline">AI-native product analytics for teams who move fast without breaking things.</p>
        <!-- Social icons -->
        <div class="social-links" role="list" aria-label="Social media links">
          <a href="#" class="social-link" aria-label="Twitter / X" role="listitem">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M2 2l5.5 6L2 16h2l4.5-5.5L13 16h3L10.5 9.5 16 2h-2L8.5 7 5 2H2z" fill="currentColor"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="LinkedIn" role="listitem">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <rect x="2" y="2" width="14" height="14" rx="3" stroke="currentColor" stroke-width="1.3"/>
              <path d="M5.5 7.5V13M5.5 5a.5.5 0 110-1 .5.5 0 010 1zM8.5 13V9.5c0-1 .7-2 2-2s2 1 2 2V13" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="GitHub" role="listitem">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M9 1.5a7.5 7.5 0 00-2.371 14.618c.375.069.512-.163.512-.362 0-.178-.006-.652-.01-1.28-2.085.454-2.526-1.004-2.526-1.004-.34-.866-.832-1.097-.832-1.097-.68-.464.052-.455.052-.455.751.053 1.147.772 1.147.772.667 1.143 1.75.813 2.177.621.067-.483.261-.813.474-1-.659-.075-1.352-.33-1.352-1.469 0-.324.116-.59.305-.797-.03-.075-.132-.378.03-.788 0 0 .248-.08.813.303A2.83 2.83 0 019 9.75c.251.001.504.034.74.1.564-.383.812-.303.812-.303.163.41.06.713.03.788.19.207.305.473.305.797 0 1.142-.695 1.393-1.357 1.466.107.092.202.273.202.55 0 .398-.004.718-.004.816 0 .2.135.434.515.36A7.501 7.501 0 009 1.5z" fill="currentColor"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Product column -->
      <nav class="footer-col" aria-label="Product links">
        <h3 class="col-title">Product</h3>
        <ul role="list">
          <li><a href="#" class="footer-link">Features</a></li>
          <li><a href="#" class="footer-link">Integrations</a></li>
          <li><a href="#" class="footer-link">Pricing</a></li>
          <li><a href="#" class="footer-link">Changelog</a></li>
          <li><a href="#" class="footer-link">Roadmap</a></li>
        </ul>
      </nav>

      <!-- Company column -->
      <nav class="footer-col" aria-label="Company links">
        <h3 class="col-title">Company</h3>
        <ul role="list">
          <li><a href="#" class="footer-link">About</a></li>
          <li><a href="#" class="footer-link">Blog</a></li>
          <li><a href="#" class="footer-link">Careers</a></li>
          <li><a href="#" class="footer-link">Press</a></li>
          <li><a href="#" class="footer-link">Contact</a></li>
        </ul>
      </nav>

      <!-- Resources column -->
      <nav class="footer-col" aria-label="Resources links">
        <h3 class="col-title">Resources</h3>
        <ul role="list">
          <li><a href="#" class="footer-link">Documentation</a></li>
          <li><a href="#" class="footer-link">API Reference</a></li>
          <li><a href="#" class="footer-link">Status</a></li>
          <li><a href="#" class="footer-link">Community</a></li>
          <li><a href="#" class="footer-link">Support</a></li>
        </ul>
      </nav>

      <!-- Legal column -->
      <nav class="footer-col" aria-label="Legal links">
        <h3 class="col-title">Legal</h3>
        <ul role="list">
          <li><a href="#" class="footer-link">Privacy Policy</a></li>
          <li><a href="#" class="footer-link">Terms of Service</a></li>
          <li><a href="#" class="footer-link">Cookie Policy</a></li>
          <li><a href="#" class="footer-link">DPA</a></li>
        </ul>
      </nav>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copy">© 2026 Nebula Labs, Inc.</p>
      <span class="concept-badge">Concept demo</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-2);
    border-top: 1px solid var(--border);
    padding: 4rem 1.5rem 2rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem 2rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    }
  }

  .footer-brand {
    grid-column: 1 / -1;
  }

  @media (min-width: 1024px) {
    .footer-brand { grid-column: auto; }
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 0.875rem;
  }

  .brand-diamond {
    background: var(--grad-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .brand-name {
    color: var(--text);
  }

  .brand-tagline {
    font-size: 0.85rem;
    color: var(--muted-2);
    line-height: 1.6;
    max-width: 220px;
    margin-bottom: 1.25rem;
  }

  .social-links {
    display: flex;
    gap: 0.6rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: var(--radius-sm);
    color: var(--muted-2);
    background: var(--surface);
    border: 1px solid var(--border);
    transition: color 0.2s, border-color 0.2s;
  }

  @media (hover: hover) {
    .social-link:hover {
      color: var(--text);
      border-color: var(--border-2);
    }
  }

  .footer-col {}

  .col-title {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--text);
    text-transform: uppercase;
    margin-bottom: 1rem;
    font-family: var(--font-head);
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--muted-2);
    transition: color 0.2s;
  }

  @media (hover: hover) {
    .footer-link:hover {
      color: var(--muted);
    }
  }

  /* Bottom bar */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--border);
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--muted-2);
  }

  .concept-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: var(--muted-2);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 0.25rem 0.65rem;
    border-radius: 100px;
  }
</style>
