---
---
<section class="pdd-section" aria-labelledby="pdd-heading">
  <div class="pdd-inner">
    <div class="pdd-header reveal">
      <div class="section-eyebrow">Product</div>
      <h2 id="pdd-heading" class="section-title">One workspace for<br/><span class="grad-text">your whole product story.</span></h2>
      <p class="section-sub">From raw events to board-ready metrics, Nebula stitches together every piece of your product data so your team can move faster, align easier, and build better.</p>
    </div>

    <div class="pdd-grid">
      <!-- Large dashboard mockup -->
      <div class="big-dashboard reveal delay-1" role="img" aria-label="Nebula product workspace dashboard">
        <div class="bd-chrome">
          <div class="bd-dots" aria-hidden="true">
            <span class="bd-dot rd"></span>
            <span class="bd-dot am"></span>
            <span class="bd-dot gr"></span>
          </div>
          <div class="bd-tabs" aria-hidden="true">
            <span class="bd-tab active">Overview</span>
            <span class="bd-tab">Funnels</span>
            <span class="bd-tab">Cohorts</span>
          </div>
          <div class="bd-actions" aria-hidden="true">
            <span class="bd-share">Share</span>
          </div>
        </div>

        <div class="bd-body" aria-hidden="true">
          <!-- Funnel viz -->
          <div class="bd-section-label">Activation Funnel — Last 30d</div>
          <div class="funnel-wrap">
            <div class="funnel-step">
              <div class="funnel-bar-wrap">
                <div class="funnel-bar" style="width:100%" data-color="violet"></div>
              </div>
              <div class="funnel-meta">
                <span class="funnel-name">Sign Up</span>
                <span class="funnel-n">12,840</span>
                <span class="funnel-pct">100%</span>
              </div>
            </div>
            <div class="funnel-step">
              <div class="funnel-bar-wrap">
                <div class="funnel-bar" style="width:72%" data-color="indigo"></div>
              </div>
              <div class="funnel-meta">
                <span class="funnel-name">Verify Email</span>
                <span class="funnel-n">9,245</span>
                <span class="funnel-pct funnel-down">↓ 72%</span>
              </div>
            </div>
            <div class="funnel-step">
              <div class="funnel-bar-wrap">
                <div class="funnel-bar" style="width:51%" data-color="indigo"></div>
              </div>
              <div class="funnel-meta">
                <span class="funnel-name">Connect Source</span>
                <span class="funnel-n">6,550</span>
                <span class="funnel-pct funnel-down">↓ 51%</span>
              </div>
            </div>
            <div class="funnel-step">
              <div class="funnel-bar-wrap">
                <div class="funnel-bar" style="width:34%" data-color="cyan"></div>
              </div>
              <div class="funnel-meta">
                <span class="funnel-name">First Query</span>
                <span class="funnel-n">4,366</span>
                <span class="funnel-pct funnel-drop">↓ 34% ⚠</span>
              </div>
            </div>
            <div class="funnel-step">
              <div class="funnel-bar-wrap">
                <div class="funnel-bar" style="width:28%" data-color="pink"></div>
              </div>
              <div class="funnel-meta">
                <span class="funnel-name">Activated</span>
                <span class="funnel-n">3,595</span>
                <span class="funnel-pct funnel-green">✓ 28%</span>
              </div>
            </div>
          </div>

          <!-- Cohort grid -->
          <div class="bd-section-label" style="margin-top:1.25rem;">Retention Cohorts (D1–D30)</div>
          <div class="cohort-grid" aria-hidden="true">
            <div class="cohort-header">
              <span>Cohort</span>
              <span>D1</span><span>D3</span><span>D7</span><span>D14</span><span>D30</span>
            </div>
            <div class="cohort-row">
              <span class="cohort-date">Jun 1</span>
              <span class="cohort-cell c-90">90%</span>
              <span class="cohort-cell c-75">75%</span>
              <span class="cohort-cell c-64">64%</span>
              <span class="cohort-cell c-52">52%</span>
              <span class="cohort-cell c-38">38%</span>
            </div>
            <div class="cohort-row">
              <span class="cohort-date">Jun 8</span>
              <span class="cohort-cell c-88">88%</span>
              <span class="cohort-cell c-73">73%</span>
              <span class="cohort-cell c-61">61%</span>
              <span class="cohort-cell c-49">49%</span>
              <span class="cohort-cell c-dim">—</span>
            </div>
            <div class="cohort-row">
              <span class="cohort-date">Jun 15</span>
              <span class="cohort-cell c-85">85%</span>
              <span class="cohort-cell c-70">70%</span>
              <span class="cohort-cell c-58">58%</span>
              <span class="cohort-cell c-dim">—</span>
              <span class="cohort-cell c-dim">—</span>
            </div>
            <div class="cohort-row">
              <span class="cohort-date">Jun 22</span>
              <span class="cohort-cell c-87">87%</span>
              <span class="cohort-cell c-72">72%</span>
              <span class="cohort-cell c-dim">—</span>
              <span class="cohort-cell c-dim">—</span>
              <span class="cohort-cell c-dim">—</span>
            </div>
          </div>

          <!-- AI insight chip -->
          <div class="insight-chip">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M7 1L8.5 5.5L13 7L8.5 8.5L7 13L5.5 8.5L1 7L5.5 5.5L7 1Z" fill="#a855f7"/>
            </svg>
            <span><strong>Nebula insight:</strong> Cohorts from Jun 8+ show 3% lower D30 retention — likely tied to the onboarding change deployed Jun 3.</span>
          </div>
        </div>
      </div>

      <!-- Right side copy/features -->
      <div class="pdd-features reveal delay-2">
        <div class="pdd-feature">
          <div class="pdd-feature-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M10 2L12.5 8.5L19 10L12.5 11.5L10 18L7.5 11.5L1 10L7.5 8.5L10 2Z" fill="url(#pfg1)"/>
              <defs>
                <linearGradient id="pfg1" x1="1" y1="2" x2="19" y2="18">
                  <stop stop-color="#8b5cf6"/><stop offset="1" stop-color="#ec4899"/>
                </linearGradient>
              </defs>
            </svg>
          </div>
          <div>
            <h3 class="pdd-feature-title">AI-powered analysis</h3>
            <p class="pdd-feature-body">Nebula doesn't just show you numbers — it tells you what they mean and what to do next.</p>
          </div>
        </div>
        <div class="pdd-feature">
          <div class="pdd-feature-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <circle cx="10" cy="10" r="8" stroke="url(#pfg2)" stroke-width="1.5"/>
              <path d="M6 10l3 3 5-5" stroke="url(#pfg2)" stroke-width="1.5" stroke-linecap="round"/>
              <defs>
                <linearGradient id="pfg2" x1="2" y1="2" x2="18" y2="18">
                  <stop stop-color="#22d3ee"/><stop offset="1" stop-color="#6366f1"/>
                </linearGradient>
              </defs>
            </svg>
          </div>
          <div>
            <h3 class="pdd-feature-title">Real-time everywhere</h3>
            <p class="pdd-feature-body">Funnels, cohorts, and dashboards update live as your users take action. No stale exports.</p>
          </div>
        </div>
        <div class="pdd-feature">
          <div class="pdd-feature-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <rect x="2" y="4" width="16" height="12" rx="2" stroke="url(#pfg3)" stroke-width="1.5"/>
              <path d="M6 8h8M6 11h5" stroke="url(#pfg3)" stroke-width="1.2" stroke-linecap="round"/>
              <defs>
                <linearGradient id="pfg3" x1="2" y1="4" x2="18" y2="16">
                  <stop stop-color="#ec4899"/><stop offset="1" stop-color="#8b5cf6"/>
                </linearGradient>
              </defs>
            </svg>
          </div>
          <div>
            <h3 class="pdd-feature-title">Shareable dashboards</h3>
            <p class="pdd-feature-body">One click to share a view with your team, execs, or investors — no extra logins needed.</p>
          </div>
        </div>
        <div class="pdd-feature">
          <div class="pdd-feature-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M10 2v16M2 10h16" stroke="url(#pfg4)" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
              <circle cx="10" cy="10" r="4" fill="url(#pfg4)" opacity="0.9"/>
              <defs>
                <linearGradient id="pfg4" x1="2" y1="2" x2="18" y2="18">
                  <stop stop-color="#8b5cf6"/><stop offset="1" stop-color="#22d3ee"/>
                </linearGradient>
              </defs>
            </svg>
          </div>
          <div>
            <h3 class="pdd-feature-title">Cross-team alignment</h3>
            <p class="pdd-feature-body">Product, growth, and engineering finally see the same numbers. One source of truth.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .pdd-section {
    padding: 6rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .pdd-section::before {
    content: '';
    position: absolute;
    top: 20%;
    left: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(236, 72, 153, 0.08) 0%, transparent 70%);
    filter: blur(80px);
    pointer-events: none;
  }

  .pdd-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .pdd-header {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--violet-2);
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.25);
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
  }

  .section-title {
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .grad-text {
    background: var(--grad-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .pdd-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .pdd-grid {
      grid-template-columns: 1fr 380px;
      gap: 3rem;
    }
  }

  /* Big dashboard */
  .big-dashboard {
    background: rgba(13, 10, 31, 0.9);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-elevated), 0 0 80px rgba(99, 102, 241, 0.08);
  }

  .bd-chrome {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.02);
  }

  .bd-dots {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .bd-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }

  .bd-dot.rd { background: #ff5f57; }
  .bd-dot.am { background: #ffbd2e; }
  .bd-dot.gr { background: #28c840; }

  .bd-tabs {
    display: flex;
    gap: 0.25rem;
  }

  .bd-tab {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted-2);
    padding: 0.25rem 0.65rem;
    border-radius: 6px;
    cursor: default;
    transition: background 0.2s;
  }

  .bd-tab.active {
    color: var(--text);
    background: rgba(139, 92, 246, 0.12);
    border: 1px solid rgba(139, 92, 246, 0.2);
  }

  .bd-actions {
    margin-left: auto;
  }

  .bd-share {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--violet-2);
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.2);
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    cursor: default;
  }

  .bd-body {
    padding: 1rem;
  }

  @media (min-width: 560px) {
    .bd-body { padding: 1.5rem; }
  }

  .bd-section-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--muted-2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  /* Funnel */
  .funnel-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .funnel-step {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .funnel-bar-wrap {
    flex: 1;
    height: 22px;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 4px;
    overflow: hidden;
    min-width: 0;
  }

  .funnel-bar {
    height: 100%;
    border-radius: 4px;
    transition: width 0.8s ease;
  }

  .funnel-bar[data-color="violet"] {
    background: linear-gradient(90deg, #8b5cf6, #a855f7);
  }

  .funnel-bar[data-color="indigo"] {
    background: linear-gradient(90deg, #6366f1, #818cf8);
  }

  .funnel-bar[data-color="cyan"] {
    background: linear-gradient(90deg, #22d3ee, #38bdf8);
  }

  .funnel-bar[data-color="pink"] {
    background: linear-gradient(90deg, #ec4899, #f472b6);
  }

  .funnel-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
    min-width: 118px;
  }

  @media (min-width: 480px) {
    .funnel-meta { gap: 0.5rem; min-width: 140px; }
  }

  .funnel-name {
    font-size: 0.66rem;
    color: var(--muted);
    width: 62px;
    font-family: var(--font-mono);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (min-width: 480px) {
    .funnel-name { font-size: 0.72rem; width: 80px; }
  }

  .funnel-n {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--text);
    width: 34px;
    text-align: right;
  }

  @media (min-width: 480px) {
    .funnel-n { font-size: 0.68rem; width: 38px; }
  }

  .funnel-pct {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--muted-2);
  }

  .funnel-down { color: var(--muted-2); }
  .funnel-drop { color: #f87171; }
  .funnel-green { color: #34d399; }

  /* Cohort grid */
  .cohort-grid {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .cohort-header, .cohort-row {
    display: grid;
    grid-template-columns: 50px repeat(5, 1fr);
    gap: 0.35rem;
    align-items: center;
  }

  .cohort-header span {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--muted-2);
    text-align: center;
  }

  .cohort-header span:first-child {
    text-align: left;
  }

  .cohort-date {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--muted-2);
  }

  .cohort-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 26px;
    border-radius: 5px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
  }

  .c-90 { background: rgba(139, 92, 246, 0.55); color: #e9d5ff; }
  .c-88 { background: rgba(139, 92, 246, 0.52); color: #e9d5ff; }
  .c-87 { background: rgba(139, 92, 246, 0.50); color: #e9d5ff; }
  .c-85 { background: rgba(139, 92, 246, 0.46); color: #e9d5ff; }
  .c-75 { background: rgba(99, 102, 241, 0.45); color: #c7d2fe; }
  .c-73 { background: rgba(99, 102, 241, 0.42); color: #c7d2fe; }
  .c-72 { background: rgba(99, 102, 241, 0.40); color: #c7d2fe; }
  .c-70 { background: rgba(99, 102, 241, 0.38); color: #c7d2fe; }
  .c-64 { background: rgba(34, 211, 238, 0.3); color: #a5f3fc; }
  .c-61 { background: rgba(34, 211, 238, 0.27); color: #a5f3fc; }
  .c-58 { background: rgba(34, 211, 238, 0.24); color: #a5f3fc; }
  .c-52 { background: rgba(34, 211, 238, 0.18); color: #a5f3fc; }
  .c-49 { background: rgba(34, 211, 238, 0.16); color: #a5f3fc; }
  .c-38 { background: rgba(236, 72, 153, 0.2); color: #fbcfe8; }
  .c-dim { background: rgba(255,255,255,0.03); color: var(--muted-2); }

  /* Insight chip */
  .insight-chip {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    margin-top: 1rem;
    padding: 0.75rem 1rem;
    background: rgba(168, 85, 247, 0.07);
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: var(--radius-md);
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .insight-chip strong {
    color: var(--violet-2);
  }

  .insight-chip svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Right side */
  .pdd-features {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .pdd-feature {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .pdd-feature-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(139, 92, 246, 0.08);
    border: 1px solid rgba(139, 92, 246, 0.18);
    border-radius: var(--radius-sm);
  }

  .pdd-feature-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.35rem;
  }

  .pdd-feature-body {
    font-size: 0.88rem;
    line-height: 1.65;
    color: var(--muted);
  }
</style>
